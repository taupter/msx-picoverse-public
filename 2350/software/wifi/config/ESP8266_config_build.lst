1358   4888 21 3C 00        ld  hl,60                       ; Wait Up To 1s
1359   488B ED 5B 76 F6     ld  de,(TXTTAB)                 ; We will borrow Basic Program memory area for now...
1360   488F DD 6B           ld  ixl,e
1361   4891 DD 62           ld  ixh,d                       ; Address in IX
1362   4893 CD 74 49        call    WAIT_MENU_CMD_RESPONSE
1363   4896 CA 25 49        jp  z,MENU_SUB_BAD_END
1364   4899                 ; Response received, nagle is the first one, ON: or OFF:
1365   4899 3E 3A           ld  a,':'
1366   489B DD 23           inc ix
1367   489D DD 23           inc ix                          ; Nagle response is two or three bytes long, let's check
1368   489F 0B              dec bc
1369   48A0 0B              dec bc                          ; Remaining bytes
1370   48A1 DD BE 00        cp  (ix+0)
1371   48A4 CA B0 48        jp  z,CHECKTIMEOUT.1
1372   48A7 DD 23           inc ix
1373   48A9 0B              dec bc                          ; Remaining bytes
1374   48AA DD BE 00        cp  (ix+0)
1375   48AD C2 25 49        jp  nz,MENU_SUB_BAD_END         ; If not here, sorry to say it is an error
1376   48B0             CHECKTIMEOUT.1:
1377   48B0 78              ld  a,b
1378   48B1 B1              or  c                           ; All data read?
1379   48B2 CA 25 49        jp  z,MENU_SUB_BAD_END          ; If so, sorry to say it is an error
1380   48B5 DD 23           inc ix                          ; At the first digit
1381   48B7 0B              dec bc                          ; Remaining bytes
1382   48B8 78              ld  a,b
1383   48B9 B1              or  c                           ; All data read?
1384   48BA CA 25 49        jp  z,MENU_SUB_BAD_END          ; If so, sorry to say it is an error
1385   48BD DD E5           push    ix                      ; This is the start of the string, save it
1386   48BF 26 00           ld  h,0                         ; No digit so far
1387   48C1                 ; It can have up to three digits
1388   48C1             CHECKTIMEOUT.2:
1389   48C1 3E 3A           ld  a,':'
1390   48C3 DD BE 00        cp  (ix+0)                      ; Check if it is the separator
1391   48C6 CA E7 48        jp  z,CHECKTIMEOUT.3            ; If it is routine will follow through
1392   48C9 DD 7E 00        ld  a,(ix+0)                    ; Get the supposed digit in A
1393   48CC 2E 3A           ld  l,'9'+1
1394   48CE BD              cp  l
1395   48CF D2 24 49        jp  nc,MENU_SUB_BAD_END_1S      ; If more than '9', sorry to say it is an error
1396   48D2 2E 30           ld  l,'0'
1397   48D4 BD              cp  l
1398   48D5 DA 24 49        jp  c,MENU_SUB_BAD_END_1S       ; If less than '0', sorry to say it is an error
1399   48D8 24              inc h                           ; It is not, so it is a digit
1400   48D9 3E 03           ld  a,3
1401   48DB BC              cp  h
1402   48DC DA 24 49        jp  c,MENU_SUB_BAD_END_1S       ; If more than three digits, sorry to say it is an error
1403   48DF DD 23           inc ix                          ; Increase pointer
1404   48E1 0B              dec bc                          ; Decrease remaining
1405   48E2 78              ld  a,b
1406   48E3 B1              or  c                           ; All data read?
1407   48E4 C2 C1 48        jp  nz,CHECKTIMEOUT.2           ; Not, so rinse and repeat
1408   48E7             CHECKTIMEOUT.3:
1409   48E7 DD 36 00 00     ld  (ix+0),0                    ; Null terminate string value
1410   48EB DD 2B           dec ix
1411   48ED DD 7E 00        ld  a,(ix+0)                    ; 1st Digit in A
1412   48F0 D6 30           sub '0'                         ; Convert it to decimal value
1413   48F2 5F              ld  e,a
1414   48F3 16 00           ld  d,0                         ; DE has first digit
1415   48F5 25              dec h                           ; Decrement digit counter
1416   48F6 28 28           jr  z,CHECKTIMEOUT.END          ; If all digits, done
1417   48F8                 ; Now second digit, multiply it by 10 and add to E, even if 90 + 9, still fits E
1418   48F8 DD 2B           dec ix
1419   48FA DD 7E 00        ld  a,(ix+0)                    ; 2nd Digit
1420   48FD D6 30           sub '0'                         ; Convert it to decimal value
1421   48FF 87              add a,a                         ; A has *2
1422   4900 4F              ld  c,a                         ; C has *2
1423   4901 87              add a,a                         ; A has *4
1424   4902 87              add a,a                         ; A has *8
1425   4903 81              add a,c                         ; A has *10
1426   4904 83              add a,e                         ; A has two digits result
1427   4905 5F              ld  e,a                         ; Back to E, DE has two digits results
1428   4906 25              dec h                           ; Decrement digit counter
1429   4907 28 17           jr  z,CHECKTIMEOUT.END          ; If all digits, done
1430   4909                 ; Now Third digit, multiply it by 100 and add to DE
1431   4909 DD 2B           dec ix
1432   490B DD 7E 00        ld  a,(ix+0)                    ; 3rd Digit
1433   490E D6 30           sub '0'                         ; Convert it to decimal value
1434   4910 87              add a,a                         ; A has *2
1435   4911 4F              ld  c,a                         ; C has *2
1436   4912 87              add a,a                         ; A has *4
1437   4913 87              add a,a                         ; A has *8
1438   4914 81              add a,c                         ; A has *10
1439   4915 26 00           ld  h,0
1440   4917 6F              ld  l,a                         ; HL has *10
1441   4918 29              add hl,hl                       ; HL has *20
1442   4919 44              ld  b,h
1443   491A 4D              ld  c,l                         ; BC has *20
1444   491B 29              add hl,hl                       ; HL has *40
1445   491C 29              add hl,hl                       ; HL has *80
1446   491D 09              add hl,bc                       ; HL has *100
1447   491E 19              add hl,de                       ; HL has three digit value
1448   491F EB              ex  de,hl                       ; now in DE
1449   4920             CHECKTIMEOUT.END:
