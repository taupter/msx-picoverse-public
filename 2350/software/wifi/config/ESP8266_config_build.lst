1929   4BB5 76              halt
1930   4BB6 76              halt
1931   4BB7 3E 3F           ld  a,CMD_QUERY_ESP
1932   4BB9                 SEND_DATA
1932   4BB9 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
1933   4BBC 21 6A 4C        ld  hl,RSP_CMD_QUERY_ESP
1934   4BBF 11 14 00        ld  de,20                       ; Short probe timeout per speed slot
1935   4BC2 3E 02           ld  a,RSP_CMD_QUERY_ESP_SIZE
1936   4BC4 CD F5 4A        call    WAIT_RESPONSE_FROM_ESP
1937   4BC7 B7              or  a
1938   4BC8 28 07           jr  z,SCAN_ESP_QUERY_SPEED_FOUND
1939   4BCA 0C              inc c
1940   4BCB 10 DF           djnz    SCAN_ESP_QUERY_SPEED_LOOP
1941   4BCD E1              pop hl
1942   4BCE D1              pop de
1943   4BCF C1              pop bc
1944   4BD0 C9              ret
1945   4BD1             SCAN_ESP_QUERY_SPEED_FOUND:
1946   4BD1 E1              pop hl
1947   4BD2 D1              pop de
1948   4BD3 C1              pop bc
1949   4BD4 C9              ret
1950   4BD5             
1951   4BD5             ;*********************************************
1952   4BD5             ;***              SET TIME                 ***
1953   4BD5             ;*** H - Hour                              ***
1954   4BD5             ;*** L - Minutes                           ***
1955   4BD5             ;*** D - Seconds                           ***
1956   4BD5             ;***                                       ***
1957   4BD5             ;*** A - 0 if Ok otherwise invalid time    ***
1958   4BD5             ;*********************************************
1959   4BD5             PATTERN_SETUP:
1960   4BD5 AF              xor a                           ; Bit-16, V9938 and V9958 only
1961   4BD6 21 88 00        ld  hl,#0088                    ; Bit-15 to 0, pattern base address = #0088
1962   4BD9 CD 49 4C        call SET_VDP_WRITE
1963   4BDC 21 E9 4B        ld  hl,PATTERN_DATA             ; Point to hl
1964   4BDF 06 60           ld  b,8*12                      ; Redraw 12 chars, max 12 chars are suggested
1965   4BE1 0E 98           ld  c,#98                       ; port #98
1966   4BE3             OUTI_TO_VRAM_TMS9918:
1967   4BE3 ED A3           outi                            ; Slower than otir but useful on TMS9918 which requires 29 T-states
1968   4BE5 C2 E3 4B        jp  nz,OUTI_TO_VRAM_TMS9918     ; Therefore, don't use 'djnz' here!
1969   4BE8 C9              ret
1970   4BE9             PATTERN_DATA:
1971   4BE9             ; Pattern-01 is CHR$(1)+CHR$(81) = SCAN_TERMINATOR_OPEN
1972   4BE9 06              db  %00000110
1973   4BEA 09              db  %00001001
1974   4BEB 09              db  %00001001
1975   4BEC FC              db  %11111100                   ; "Opened Padlock"
1976   4BED FC              db  %11111100
1977   4BEE FC              db  %11111100
1978   4BEF FC              db  %11111100
1979   4BF0 00              db  %00000000
1980   4BF1             ; Pattern-02 is CHR$(1)+CHR$(82) = SCAN_TERMINATOR_ENC
1981   4BF1 30              db  %00110000
1982   4BF2 48              db  %01001000
1983   4BF3 48              db  %01001000
1984   4BF4 FC              db  %11111100                   ; "Closed Padlock"
1985   4BF5 FC              db  %11111100
1986   4BF6 FC              db  %11111100
1987   4BF7 FC              db  %11111100
1988   4BF8 00              db  %00000000
1989   4BF9             ; Pattern-03 is CHR$(1)+CHR$(83) = Wi-Fi Connected to the AP:
1990   4BF9 00              db  %00000000
1991   4BFA 00              db  %00000000
1992   4BFB 70              db  %01110000
1993   4BFC 70              db  %01110000                   ; "Full Access Point"
1994   4BFD 70              db  %01110000
1995   4BFE 20              db  %00100000
1996   4BFF 20              db  %00100000
1997   4C00 70              db  %01110000
1998   4C01             ; Pattern-04 is CHR$(1)+CHR$(84) = Wi-Fi Failed to connect to:
1999   4C01 00              db  %00000000
2000   4C02 88              db  %10001000
2001   4C03 50              db  %01010000
2002   4C04 20              db  %00100000                   ; "X"
2003   4C05 50              db  %01010000
2004   4C06 88              db  %10001000
2005   4C07 00              db  %00000000
2006   4C08 00              db  %00000000
2007   4C09             ; Pattern-05 is CHR$(1)+CHR$(85) = Requesting connection to:
2008   4C09 00              db  %00000000
2009   4C0A 00              db  %00000000
2010   4C0B 50              db  %01010000
2011   4C0C 20              db  %00100000                   ; "Partial Access Point"
2012   4C0D 50              db  %01010000
2013   4C0E 20              db  %00100000
2014   4C0F 20              db  %00100000
2015   4C10 70              db  %01110000
2016   4C11             ; Pattern-06 is CHR$(1)+CHR$(86) = Wi-Fi Did not find the AP:
2017   4C11 00              db  %00000000
2018   4C12 70              db  %01110000
2019   4C13 88              db  %10001000
2020   4C14 10              db  %00010000                   ; "?"
2021   4C15 20              db  %00100000
2022   4C16 00              db  %00000000
2023   4C17 20              db  %00100000
2024   4C18 00              db  %00000000
2025   4C19             ; Pattern-07 is CHR$(1)+CHR$(87) = Wi-Fi is Idle, AP configured:
2026   4C19 00              db  %00000000
2027   4C1A 00              db  %00000000
2028   4C1B 00              db  %00000000
2029   4C1C 20              db  %00100000                   ; "i"
2030   4C1D 00              db  %00000000
2031   4C1E 20              db  %00100000
2032   4C1F 20              db  %00100000
2033   4C20 70              db  %01110000
2034   4C21             ; Pattern-08 is CHR$(1)+CHR$(88) = Left Middle Wave
2035   4C21 00              db  %00000000
2036   4C22 20              db  %00100000
2037   4C23 40              db  %01000000
2038   4C24 40              db  %01000000                   ; "("
2039   4C25 40              db  %01000000
2040   4C26 20              db  %00100000
2041   4C27 00              db  %00000000
2042   4C28 00              db  %00000000
2043   4C29             ; Pattern-09 is CHR$(1)+CHR$(89) = Right Middle Wave
2044   4C29 00              db  %00000000
2045   4C2A 20              db  %00100000
2046   4C2B 10              db  %00010000
2047   4C2C 10              db  %00010000                   ; ")"
2048   4C2D 10              db  %00010000
2049   4C2E 20              db  %00100000
2050   4C2F 00              db  %00000000
2051   4C30 00              db  %00000000
2052   4C31             ; Pattern-10 is CHR$(1)+CHR$(90) = Wi-Fi is reconnecting to:
2053   4C31 00              db  %00000000
2054   4C32 00              db  %00000000
2055   4C33 00              db  %00000000
2056   4C34 A8              db  %10101000                   ; "..."
2057   4C35 00              db  %00000000
2058   4C36 00              db  %00000000
2059   4C37 00              db  %00000000
2060   4C38 00              db  %00000000
2061   4C39             ; Pattern-11 is CHR$(1)+CHR$(91) = Double Dot
2062   4C39 00              db  %00000000
2063   4C3A 00              db  %00000000
2064   4C3B 00              db  %00000000
2065   4C3C 00              db  %00000000                   ; ".."
2066   4C3D 00              db  %00000000
2067   4C3E 66              db  %01100110
2068   4C3F 66              db  %01100110
2069   4C40 00              db  %00000000
2070   4C41             ; Pattern-12 is CHR$(1)+CHR$(92) = Copyright
2071   4C41 38              db  %00111000
2072   4C42 44              db  %01000100
2073   4C43 BA              db  %10111010
2074   4C44 A2              db  %10100010                   ; "(c)"
2075   4C45 BA              db  %10111010
2076   4C46 44              db  %01000100
2077   4C47 38              db  %00111000
2078   4C48 00              db  %00000000
2079   4C49             ; http://map.grauw.nl/articles/vdp_tut.php
2080   4C49             ; Set VDP address counter to write from address AHL (17-bits)
2081   4C49             ; Enables the interrupts
2082   4C49             SET_VDP_WRITE:
2083   4C49 CB 04           rlc h
2084   4C4B 17              rla
2085   4C4C CB 04           rlc h
2086   4C4E 17              rla
2087   4C4F CB 3C           srl h
2088   4C51 CB 3C           srl h
2089   4C53 F3              di
2090   4C54 D3 99           out (#99),a
2091   4C56 3E 8E           ld  a,14+128
2092   4C58 D3 99           out (#99),a
2093   4C5A 7D              ld  a,l
2094   4C5B 00              nop                             ; Do not remove this 'nop' here!
2095   4C5C D3 99           out (#99),a
2096   4C5E 7C              ld  a,h
2097   4C5F F6 40           or  64
2098   4C61 FB              ei
2099   4C62 D3 99           out (#99),a
2100   4C64 C9              ret
