2102   4C65             ;*********************************************
2103   4C65             ;***    ESP Specific Commands/Responses    ***
2104   4C65             ;*********************************************
2105   4C65             ; Cold reset of ESP firmware
2106   4C65             CMD_RESET_ESP           equ 'R'
2107   4C65             ; Warm reset of ESP firmware
2108   4C65             CMD_WRESET_ESP          equ 'W'
2109   4C65             ; Hold Wi-Fi Connection On
2110   4C65             CMD_WIFIHOLD_ESP        equ 'H'
2111   4C65             ; Release Wi-Fi Connection Hold
2112   4C65             CMD_WIFIRELEASE_ESP     equ 'h'
2113   4C65             ; Query Auto Clock settings
2114   4C65             CMD_QUERY_ACLK_SETTINGS equ 'c'
2115   4C65             ; Set Auto Clock settings
2116   4C65             CMD_SET_ACLK_SETTINGS   equ 'C'
2117   4C65             ; Query ESP settings
2118   4C65             CMD_QUERY_ESP_SETTINGS  equ 'Q'
2119   4C65             ; Set Timer Value
2120   4C65             CMD_TIMER_SET           equ 'T'
2121   4C65             ; Turn Nagle On
2122   4C65             CMD_NAGLE_ON            equ 'D'
2123   4C65             ; Turn Nagle Off
2124   4C65             CMD_NAGLE_OFF           equ 'N'
2125   4C65             ; Request to connect to a network
2126   4C65             CMD_WIFI_CONNECT        equ 'A'
2127   4C65             ; Request to start network scan
2128   4C65             CMD_SCAN_START          equ 'S'
2129   4C65             ; Request network scan result
2130   4C65             CMD_SCAN_RESULTS        equ 's'
2131   4C65             ; Request AP Status
2132   4C65             CMD_AP_STS              equ 'g'
2133   4C65             ; After finishing Warm reset, ESP returns ready
2134   4C65 5265616479  RSP_CMD_RESET_ESP       db  "Ready"
2135   4C6A             RSP_CMD_RESET_ESP_SIZE  equ 5
2136   4C6A             ; Query ESP Presence
2137   4C6A             CMD_QUERY_ESP           equ '?'
2138   4C6A             ; Query response
2139   4C6A 4F 4B       RSP_CMD_QUERY_ESP       db  "OK"
2140   4C6C             RSP_CMD_QUERY_ESP_SIZE  equ 2
