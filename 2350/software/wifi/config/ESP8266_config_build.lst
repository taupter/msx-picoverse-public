1617   4A05             
1618   4A05             ; WAIT an ESP Wi-Fi Scan command Response
1619   4A05             ; Inputs:
1620   4A05             ; A -> Command Code
1621   4A05             ; HL -> Timeout
1622   4A05             ; IX -> Where to store response
1623   4A05             ;
1624   4A05             ; Returns:
1625   4A05             ; Flag Z is zero if failure, non zero if success
1626   4A05             ; A is the number of access points scanned
1627   4A05             ;
1628   4A05             ; Response is stored as:
1629   4A05             ; Access Point SSID zero terminated and after first 0
1630   4A05             ; 0 if Open otherwise requires a password to join
1631   4A05             ; And this repeats...
1632   4A05             ;
1633   4A05             ; Affect:
1634   4A05             ; AF , BC and HL
1635   4A05             ;
1636   4A05             WAIT_MENU_SCMD_RESPONSE:
1637   4A05 D5              push    de
1638   4A06 DD E5           push    ix
1639   4A08 57              ld  d,a                         ; Command to wait in D
1640   4A09             WAIT_MENU_SCMD_RESPONSE_ST1:
1641   4A09                 LOAD_STS_PORT_IN_A
1641   4A09 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
1642   4A0C CB 6F           bit 5,a                         ; If nz Port #07 is not available
1643   4A0E C2 8D 4A        jp  nz,WAIT_MENU_SCMD_RESPONSE_END_NOK
1644   4A11 CB 47           bit 0,a                         ; If nz has data
1645   4A13 20 08           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST1.1
1646   4A15 CD 96 4A        call    HLTIMEOUT
1647   4A18 20 EF           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST1
1648   4A1A C3 89 4A        jp  WAIT_MENU_SCMD_RESPONSE_END ; If time out waiting, return
1649   4A1D             WAIT_MENU_SCMD_RESPONSE_ST1.1:
1650   4A1D                 ; nz, check the data
1651   4A1D                 RECEIVE_DATA
1651   4A1D 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
1652   4A20 BA              cp  d                           ; Is response of our command?
1653   4A21 20 E6           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST1
1654   4A23                 ; Now get return code, if return code other than 0, it is finished
1655   4A23             WAIT_MENU_SCMD_RESPONSE_RC:
1656   4A23                 CHECK_DATA
1656   4A23 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
1656   4A26 CB 47       >    bit 0,a                         ; If nz has data
1657   4A28 20 08           jr  nz,WAIT_MENU_SCMD_RESPONSE_RC.1
1658   4A2A CD 96 4A        call    HLTIMEOUT
1659   4A2D 20 F4           jr  nz,WAIT_MENU_SCMD_RESPONSE_RC
1660   4A2F C3 89 4A        jp  WAIT_MENU_SCMD_RESPONSE_END ; If time out waiting, return
1661   4A32             WAIT_MENU_SCMD_RESPONSE_RC.1:
1662   4A32                 RECEIVE_DATA
1662   4A32 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
1663   4A35 B7              or  a                           ; 0?
1664   4A36                 ; If not, done
1665   4A36 C2 8D 4A        jp  nz,WAIT_MENU_SCMD_RESPONSE_END_NOK
1666   4A39                 ; Next byte is how many access points are available
1667   4A39             WAIT_MENU_SCMD_RESPONSE_ST2A:
1668   4A39                 CHECK_DATA
1668   4A39 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
1668   4A3C CB 47       >    bit 0,a                         ; If nz has data
1669   4A3E 20 08           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST2A.1
1670   4A40 CD 96 4A        call    HLTIMEOUT
1671   4A43 20 F4           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST2A
1672   4A45 C3 89 4A        jp  WAIT_MENU_SCMD_RESPONSE_END ; If time out waiting, return
1673   4A48             WAIT_MENU_SCMD_RESPONSE_ST2A.1:
1674   4A48                 RECEIVE_DATA
1674   4A48 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
1675   4A4B 47              ld  b,a                         ; Save in B
1676   4A4C 4F              ld  c,a                         ; And C as well
1677   4A4D                 ; Now should loop this until c is 0, c will control access point received count
1678   4A4D             WAIT_MENU_SCMD_RESPONSE_ST2B:
1679   4A4D                 CHECK_DATA
1679   4A4D 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
1679   4A50 CB 47       >    bit 0,a                         ; If nz has data
1680   4A52 20 08           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST2B.1
1681   4A54 CD 96 4A        call    HLTIMEOUT
1682   4A57 20 F4           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST2B
1683   4A59 C3 89 4A        jp  WAIT_MENU_SCMD_RESPONSE_END ; If time out waiting, return
1684   4A5C             WAIT_MENU_SCMD_RESPONSE_ST2B.1:
1685   4A5C                 RECEIVE_DATA
1685   4A5C 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
1686   4A5F DD 77 00        ld  (ix+0),a
1687   4A62 DD 23           inc ix                          ; Increment pointer
1688   4A64 B7              or  a                           ; Terminator of AP Name?
1689   4A65 20 E6           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST2B
1690   4A67                 ; Get encryption
1691   4A67             WAIT_MENU_SCMD_RESPONSE_GET_ENC:
1692   4A67                 CHECK_DATA
1692   4A67 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
1692   4A6A CB 47       >    bit 0,a                         ; If nz has data
1693   4A6C 20 08           jr  nz,WAIT_MENU_SCMD_RESPONSE_GET_ENC.1
1694   4A6E CD 96 4A        call    HLTIMEOUT
1695   4A71 20 F4           jr  nz,WAIT_MENU_SCMD_RESPONSE_GET_ENC
1696   4A73 C3 89 4A        jp  WAIT_MENU_SCMD_RESPONSE_END  ; If time out waiting, return
1697   4A76             WAIT_MENU_SCMD_RESPONSE_GET_ENC.1:
1698   4A76                 RECEIVE_DATA            ; Get data
1698   4A76 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
1699   4A79 D6 4F           sub 'O'                         ; If O, open, will be 0, otherwise, will be notzero
1700   4A7B DD 77 00        ld  (ix+0),a                    ; Put it in the buffer
1701   4A7E DD 23           inc ix                          ; Increment pointer
1702   4A80 0D              dec c                           ; Decrement counter
1703   4A81 AF              xor a
1704   4A82 B1              or  c                           ; Is counter 0?
1705   4A83                 ; If not continue getting more SSIDs
1706   4A83 20 C8           jr  nz,WAIT_MENU_SCMD_RESPONSE_ST2B
1707   4A85                 ; It is zero, so, done
1708   4A85             WAIT_MENU_SCMD_RESPONSE_END_OK:
1709   4A85 3E 01           ld  a,1
1710   4A87 B7              or  a                           ; NZ to indicate success
1711   4A88 78              ld  a,b                         ; Number of APs in A
1712   4A89             WAIT_MENU_SCMD_RESPONSE_END:
1713   4A89 DD E1           pop ix
1714   4A8B D1              pop de
1715   4A8C C9              ret
1716   4A8D             WAIT_MENU_SCMD_RESPONSE_END_NOK:
1717   4A8D 21 00 00        ld  hl,0
1718   4A90 47              ld  b,a                         ; Return code in B
1719   4A91 AF              xor a
1720   4A92 DD E1           pop ix
1721   4A94 D1              pop de
1722   4A95 C9              ret
1723   4A96             
1724   4A96             ; This routine will check if HL is 0, if it is, will return immediatelly
1725   4A96             ; If it is not, will decrease HL value and halt (wait one interrupt)
1726   4A96             HLTIMEOUT:
1727   4A96 7C              ld  a,h
1728   4A97 B5              or  l
1729   4A98 C8              ret z
1730   4A99 2B              dec hl
1731   4A9A 76              halt
