1852   4B2A             ;*********************************************
1853   4B2A             ;***              RESET ESP                ***
1854   4B2A             ;*** If RESET ok, A will be 0, otherwise   ***
1855   4B2A             ;*** failure                               ***
1856   4B2A             ;*********************************************
1857   4B2A             RESET_ESP:
1858   4B2A                 ; Is ESP installed?
1859   4B2A                 CLEAR_UART                      ; Clear UART
1859   4B2A 3E 14       >    ld  a,20
1859   4B2C 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
1860   4B2F 3E 51           ld  a,'Q'
1861   4B31 CD A2 00        call    CHPUT
1862   4B34 3E 3F           ld  a,CMD_QUERY_ESP
1863   4B36                 SEND_DATA
1863   4B36 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
1864   4B39 3E 71           ld  a,'q'
1865   4B3B CD A2 00        call    CHPUT
1866   4B3E 21 6A 4C        ld  hl,RSP_CMD_QUERY_ESP        ; Expected response
1867   4B41 11 3C 00        ld  de,60                       ; Up to 1s @ 60Hz
1868   4B44 3E 02           ld  a,RSP_CMD_QUERY_ESP_SIZE    ; Size of response
1869   4B46 CD F5 4A        call    WAIT_RESPONSE_FROM_ESP
1870   4B49 B7              or  a
1871   4B4A 3E 01           ld  a,1
1872   4B4C 28 0B           jr  z,RESET_ESP_INIT            ; ESP Found
1873   4B4E 3E 58           ld  a,'X'
1874   4B50 CD A2 00        call    CHPUT
1875   4B53 CD A5 4B        call    SCAN_ESP_QUERY_SPEED
1876   4B56 06 00           ld  b,0                         ; 0 if no response
1877   4B58 C9              ret
1878   4B59             RESET_ESP_INIT:
1879   4B59 3E 49           ld  a,'I'
1880   4B5B CD A2 00        call    CHPUT
1881   4B5E 06 03           ld  b,3                         ; Retry up to 10 times
1882   4B60             RESET_ESP_LOOP:
1883   4B60                 CLEAR_UART
1883   4B60 3E 14       >    ld  a,20
1883   4B62 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
1884   4B65 3E 52           ld  a,'R'
1885   4B67 CD A2 00        call    CHPUT
1886   4B6A                 SET_SPEED
1886   4B6A AF          >    xor a
1886   4B6B 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
1887   4B6E 3E 53           ld  a,'S'
1888   4B70 CD A2 00        call    CHPUT
1889   4B73 76              halt
1890   4B74 76              halt                            ; Wait a little to make sure speed is adjusted
1891   4B75 3E 57           ld  a,CMD_WRESET_ESP
1892   4B77                 SEND_DATA
1892   4B77 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
1893   4B7A 3E 57           ld  a,'W'
1894   4B7C CD A2 00        call    CHPUT
1895   4B7F 21 65 4C        ld  hl,RSP_CMD_RESET_ESP        ; Expected response
1896   4B82 11 5A 00        ld  de,90                       ; Up to 1.5s @ 60Hz
1897   4B85 3E 05           ld  a,RSP_CMD_RESET_ESP_SIZE    ; Size of response
1898   4B87 C5              push    bc                      ; Save retry counter
1899   4B88 CD F5 4A        call    WAIT_RESPONSE_FROM_ESP
1900   4B8B C1              pop bc                          ; restore retry counter
1901   4B8C B7              or  a                           ; Did WAIT RESPONSE return zero?
1902   4B8D 20 07           jr  nz,RESET_ESP_LOOP_FAIL
1903   4B8F 3E 4F           ld  a,'O'
1904   4B91 CD A2 00        call    CHPUT
1905   4B94 AF              xor a                           ; A=0, success (CHPUT clobbered flags so cannot rely on ret z)
1906   4B95 C9              ret                             ; Warm Reset Ok
1907   4B96             RESET_ESP_LOOP_FAIL:
1908   4B96 3E 78           ld  a,'x'
1909   4B98 CD A2 00        call    CHPUT
1910   4B9B 10 C3           djnz RESET_ESP_LOOP             ; No, decrement retry counter and let the loop check
1911   4B9D                 ; No more retries? Then check if it is old ESP FW
1912   4B9D             RESET_CHK_IF_INSTALLED:
1913   4B9D                 ; No more retries? Then it is old ESP FW
1914   4B9D 3E 46           ld  a,'F'
1915   4B9F CD A2 00        call    CHPUT
1916   4BA2 06 01           ld  b,1
1917   4BA4 C9              ret
