1920   4BA5 C5              push    bc
1921   4BA6 D5              push    de
1922   4BA7 E5              push    hl
1923   4BA8 0E 00           ld  c,0
1924   4BAA 06 0A           ld  b,10
1925   4BAC             SCAN_ESP_QUERY_SPEED_LOOP:
1926   4BAC                 CLEAR_UART
