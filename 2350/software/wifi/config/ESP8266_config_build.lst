0001   0000             ; ESP8266 Wi-Fi Configuration ROM v.1.3
0002   0000             ; PICOVERSE UART version
0003   0000             ; Oduvaldo Pavan Junior
0004   0000             ; ducasp@gmail.com
0005   0000             ;    This ROM exposes only the ESP8266 setup menu when launched from
0006   0000             ;    MSX PicoVerse Explorer F4. It does not install UNAPI hooks in memory.
0007   0000             ;
0008   0000             ; Pieces of this code were based on DENYOTCP.ASM (Denyonet ROM)
0009   0000             ; made by Konamiman
0010   0000             ;
0011   0000             ; This code also has contributions from KdL, most specifically in the Wi-Fi
0012   0000             ; setup menus and functionality, he has helped quite a lot to get it to the
0013   0000             ; final format and functionality, thanks!
0014   0000             ;
0015   0000             ; The MSX PICO version of this code has contribution from Jeroen Taverne That
0016   0000             ; helped making some MACROs on the fixed / non speed optimized loop I/O parts
0017   0000             ; of the code so we can easily switch this from I/O based to Memory Based.
0018   0000             ;
0019   0000             ; Note: this implementation depends upon ESP8266 having compatible PicoVerse
0020   0000             ; firmware flashed. This ROM only configures that firmware.
0021   0000             ;
0022   0000             ; Usage is free as long as you publish your code changes. If you make a profit
0023   0000             ; selling something using this code, a suggestion is that you donate one or two
0024   0000             ; pieces of the hardware to the MSX DEV contest to be awarded to MSX DEV winners
0025   0000             ; as this shouldn't cost much and perhaps will bring interest on developers to
0026   0000             ; make games that support internet :)
0027   0000             ;
0028   0000             ; If running the SETUP menu, we are going to "borrow" BASIC program area, that
0029   0000             ; is saved at TXTTAB. We can't allocate memory at this point as any possible
0030   0000             ; disk rom might be sitting on a slot that has not been initialized and results
0031   0000             ; could be bad. The BASIC program area trick should be safe, unless some other
0032   0000             ; cartridge runs a BASIC software for something (i.e.: wait disks be initialized
0033   0000             ; ), in such case, that BASIC software or trick will most likely be corrupted
0034   0000             ; after running our setup.
0035   0000             ; ESC releases the ESP8266 hold, writes CONFIG_RETURN_MENU to the PicoVerse F2
0036   0000             ; memory port, and restarts the MSX so Explorer can reload its menu.
0037   0000             
0038   0000             ;*************************
0039   0000             ;***  BUILD DEFINITIONS **
0040   0000             ;*************************
0041   0000             
0042   0000             ;--- Use memory mapped IO or not...
0043   0000             USE_MEM_IO:             equ 1
0044   0000             
0045   0000             ;*******************
0046   0000             ;***  CONSTANTS  ***
0047   0000             ;*******************
0048   0000             
0049   0000             ;--- System variables and routines:
0050   0000             CHGMOD:                 equ #005F
0051   0000             CHSNS:                  equ #009C
0052   0000             CHGET:                  equ #009F
0053   0000             CHPUT:                  equ #00A2
0054   0000             BEEP:                   equ #00C0
0055   0000             KILBUF:                 equ #0156
0056   0000             LINLEN:                 equ #F3B0
0057   0000             CLIKSW:                 equ #F3DB
0058   0000             TXTTAB:                 equ #F676
0059   0000             CSRSW:                  equ #FCA9
0060   0000             
0061   0000             
0062   0000             ;--- Memory ports:
0063   0000             MEM_OUT_CMD_PORT:       equ #7F06
0064   0000             MEM_OUT_TX_PORT:        equ #7F07
0065   0000             MEM_IN_DATA_PORT:       equ #7F06
0066   0000             MEM_IN_STS_PORT:        equ #7F07
0067   0000             MEM_PORT_F2:            equ #7F05
0068   0000             CONFIG_RETURN_MENU:     equ #E0
0069   0000             
0070   0000             ;--- I/O ports:
0071   0000             OUT_CMD_PORT:           equ #06
0072   0000             OUT_TX_PORT:            equ #07
0073   0000             IN_DATA_PORT:           equ #06
0074   0000             IN_STS_PORT:            equ #07
0075   0000             PORT_F2:                equ #F2
0076   0000             
0077   0000             
0078   0000                 if USE_MEM_IO = 1
0079   0000               MACRO SET_SPEED
0080   0000~                xor a
0081   0000~                ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0082   0000               ENDM
0083   0000             
0084   0000                 MACRO WRITE_CMD_PORT_A
0085   0000~                    ld  (MEM_OUT_CMD_PORT),a
0086   0000                 ENDM
0087   0000             
0088   0000               MACRO CLEAR_UART
0089   0000~                ld  a,20
0090   0000~                ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0091   0000               ENDM
0092   0000             
0093   0000               MACRO SEND_DATA
0094   0000~                ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0095   0000               ENDM
0096   0000             
0097   0000               MACRO RECEIVE_DATA
0098   0000~                ld a,(MEM_IN_DATA_PORT)
0099   0000               ENDM
0100   0000             
0101   0000               MACRO LOAD_STS_PORT_IN_A
0102   0000~                ld  a,(MEM_IN_STS_PORT)
0103   0000               ENDM
0104   0000             
0105   0000               MACRO CHECK_DATA
0106   0000~                ld  a,(MEM_IN_STS_PORT)
0107   0000~                bit 0,a                         ; If nz has data
0108   0000               ENDM
0109   0000             
0110   0000               MACRO CHECK_QUICK_RECEIVE
0111   0000~                ld  a,(MEM_IN_STS_PORT)
0112   0000~                bit 3,a                         ; Quick Receive Supported?
0113   0000               ENDM
0114   0000             
0115   0000               MACRO CHECK_BUFFER_UNDERRUN
0116   0000~                ld  a,(MEM_IN_STS_PORT)
0117   0000~                bit 4,a                         ; Buffer underrun?
0118   0000               ENDM
0119   0000             
0120   0000               MACRO READ_F2
0121   0000~                ld  a,(MEM_PORT_F2)
0122   0000               ENDM
0123   0000             
0124   0000               MACRO WRITE_F2
0125   0000~                ld  (MEM_PORT_F2),a
0126   0000               ENDM
0127   0000                 else
0128   0000~            
0129   0000~              MACRO SET_SPEED
0130   0000~                xor a
0131   0000~                out (OUT_CMD_PORT),a            ; Clear UART
0132   0000~              ENDM
0133   0000~            
0134   0000~                MACRO WRITE_CMD_PORT_A
0135   0000~                    out (OUT_CMD_PORT),a
0136   0000~                ENDM
0137   0000~            
0138   0000~              MACRO CLEAR_UART
0139   0000~                ld  a,20
0140   0000~                out (OUT_CMD_PORT),a            ; Clear UART
0141   0000~              ENDM
0142   0000~            
0143   0000~              MACRO SEND_DATA
0144   0000~                out (OUT_TX_PORT),a             ; Just send, no need to wait response
0145   0000~              ENDM
0146   0000~            
0147   0000~              MACRO RECEIVE_DATA
0148   0000~                in a,(IN_DATA_PORT)
0149   0000~              ENDM
0150   0000~            
0151   0000~              MACRO LOAD_STS_PORT_IN_A
0152   0000~                in  a,(IN_STS_PORT)
0153   0000~              ENDM
0154   0000~            
0155   0000~              MACRO CHECK_DATA
0156   0000~                in  a,(IN_STS_PORT)
0157   0000~                bit 0,a                         ; If nz has data
0158   0000~              ENDM
0159   0000~            
0160   0000~              MACRO CHECK_QUICK_RECEIVE
0161   0000~                ld  a,(IN_STS_PORT)
0162   0000~                bit 3,a                         ; Quick Receive Supported?
0163   0000~              ENDM
0164   0000~            
0165   0000~              MACRO CHECK_BUFFER_UNDERRUN
0166   0000~                in  a,(IN_STS_PORT)
0167   0000~                bit 4,a                         ; Buffer underrun?
0168   0000~              ENDM
0169   0000~            
0170   0000~              MACRO READ_F2
0171   0000~                in  a,(PORT_F2)
0172   0000~              ENDM
0173   0000~            
0174   0000~              MACRO WRITE_F2
0175   0000~                out (PORT_F2),a
0176   0000~              ENDM
0177   0000                 endif
0178   0000             
0179   0000             ;--- Scan Page Size
0180   0000             SCAN_MAX_PAGE_SIZE      equ 8
0181   0000             
0182   0000             ;************************
0183   0000             ;***  MSX ROM HEADER  ***
0184   0000             ;************************
0185   0000                 org #4000
0186   4000 41 42           db                  #41,#42
0187   4002 10 40           dw                  INIT_CONFIG ; Enter Wi-Fi setup directly
0188   4004 00 00           dw                  0           ; Statement
0189   4006 00 00           dw                  0           ; Device
0190   4008 00 00           dw                  0           ; Text
0191   400A 00              ds                  6           ; Reserved
0192   4010             
0193   4010             ;==================
0194   4010             ;===  Start-up  ===
0195   4010             ;==================
0196   4010             
0197   4010             INIT_CONFIG:
0198   4010 7C              ld  a,h                         ; Test if mirrored and executing in wrong page
0199   4011 FE 40           cp  #40
0200   4013 C0              ret nz
0201   4014 AF              xor a
0202   4015 32 A9 FC        ld  (CSRSW),a                   ; cursor display is disabled
0203   4018 32 DB F3        ld  (CLIKSW),a                  ; key click disabled
0204   401B 3E 01           ld  a,1
0205   401D F7              rst #30
0206   401E 00              db  0
0207   401F 5F 00           dw  CHGMOD                      ; SCREEN 1
0208   4021 3E 1D           ld  a,29                        ; WIDTH 29
0209   4023 32 B0 F3        ld  (LINLEN),a
0210   4026 C3 3F 40        jp  ENTERING_ESPSETUP
0211   4029             
0212   4029             ;============================
0213   4029             ;===  SETUP Menu Routines  ==
0214   4029             ;===       Main Menu       ==
0215   4029             ;============================
0216   4029             ESPSETUP.EXIT:
0217   4029 3E 0C           ld  a,CLS
0218   402B CD A2 00        call    CHPUT
0219   402E             CONFIG_RETURN_TO_EXPLORER:
0220   402E                 CLEAR_UART
0220   402E 3E 14       >    ld  a,20
0220   4030 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0221   4033 3E 68           ld  a,CMD_WIFIRELEASE_ESP
0222   4035                 SEND_DATA
0222   4035 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0223   4038 3E E0           ld  a,CONFIG_RETURN_MENU
0224   403A                 WRITE_F2
0224   403A 32 05 7F    >    ld  (MEM_PORT_F2),a
0225   403D C7              rst #00
0226   403E C7              rst #00
0227   403F             ENTERING_ESPSETUP:
0228   403F 21 6C 4C        ld  hl,ENTERING_WIFI_SETUP
0229   4042 CD 9C 4A        call    PRINTHL
0230   4045 CD D5 4B        call    PATTERN_SETUP
0231   4048 CD 0D 48        call    WAIT_250MS_AND_THEN_CONTINUE
0232   404B                 ; Hold Wi-Fi Connection On
0233   404B                 CLEAR_UART
0233   404B 3E 14       >    ld  a,20
0233   404D 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0234   4050                 SET_SPEED
0234   4050 AF          >    xor a
0234   4051 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0235   4054 3E 48           ld  a,CMD_WIFIHOLD_ESP
0236   4056                 SEND_DATA
0236   4056 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0237   4059 21 3C 00        ld  hl,60                       ; Up to 1s time-out
0238   405C 3E 48           ld  a,CMD_WIFIHOLD_ESP
0239   405E CD 2F 49        call    WAIT_MENU_QCMD_RESPONSE ; Wait quick response
0240   4061                 ; We do not want to error here, just in case user still need to upgrade ESP firmware
0241   4061                 ; Whether response ok or hold-fail, fall through to ESPSETUP
0242   4061             ESPSETUP:
0243   4061 CD 2A 4B        call    RESET_ESP
0244   4064 B7              or  a
0245   4065 C2 46 41        jp  nz,CONFIG_ESP_NOT_FOUND     ; Not well, ESP was not found
0246   4068                 ; Well, if reset successful, continue
0247   4068 21 88 4C        ld  hl,WELCOME
0248   406B CD 9C 4A        call    PRINTHL
0249   406E                 CHECK_QUICK_RECEIVE
0249   406E 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
0249   4071 CB 5F       >    bit 3,a                         ; Quick Receive Supported?
0250   4073 20 08           jr  nz,ESPSETUP.2NF             ; If yes, tells Quick Receive support
0251   4075 21 F3 4C        ld  hl,WELCOME_SF2
0252   4078 CD 9C 4A        call    PRINTHL                 ; Print Welcome message no QR
0253   407B 18 06           jr  ESPSETUP.3NF
0254   407D             ESPSETUP.2NF:
0255   407D 21 D7 4C        ld  hl,WELCOME_SF
0256   4080 CD 9C 4A        call    PRINTHL                 ; Print Welcome message QR
0257   4083             ESPSETUP.3NF:
0258   4083 21 13 4D        ld  hl,WELCOME_CS
0259   4086 CD 9C 4A        call    PRINTHL                 ; Print Wi-Fi is reconnecting to:
0260   4089             ESPSETUP_NEXT:
0261   4089 CD 56 01        call    KILBUF                  ; Clear Keyboard Buffer
0262   408C 21 3D 4D        ld  hl,WELCOME_NEXT
0263   408F CD 9C 4A        call    PRINTHL
0264   4092 21 47 4D        ld  hl,WELCOME_SF_NEXT
0265   4095 CD 9C 4A        call    PRINTHL                 ; Print Empty Welcome message
0266   4098 CD 2E 41        call    GET_AP_STAT
0267   409B CA D3 40        jp  z,ESPSETUP_NEXT.1G          ; Won't block in case of error
0268   409E                 ; Success, so connection state is in IX+0, then, zero terminated string with SSID starting at IX+1
0269   409E DD 7E 00        ld  a,(ix+0)
0270   40A1 21 4A 4D        ld  hl,WELCOME_CS0_NEXT
0271   40A4 FE 00           cp  0
0272   40A6 28 1F           jr  z,ESPSETUP_NEXT.2F
0273   40A8 21 74 4D        ld  hl,WELCOME_CS1_NEXT
0274   40AB FE 01           cp  1
0275   40AD 28 18           jr  z,ESPSETUP_NEXT.2F
0276   40AF 21 7D 4D        ld  hl,WELCOME_CS2_NEXT
0277   40B2 FE 02           cp  2
0278   40B4 28 11           jr  z,ESPSETUP_NEXT.2F
0279   40B6 21 A7 4D        ld  hl,WELCOME_CS3_NEXT
0280   40B9 FE 03           cp  3
0281   40BB 28 0A           jr  z,ESPSETUP_NEXT.2F
0282   40BD 21 D1 4D        ld  hl,WELCOME_CS4_NEXT
0283   40C0 FE 04           cp  4
0284   40C2 28 03           jr  z,ESPSETUP_NEXT.2F
0285   40C4 21 FB 4D        ld  hl,WELCOME_CS5_NEXT
0286   40C7             ESPSETUP_NEXT.2F:
0287   40C7 FD 67           ld  iyh,a                       ; Save current conn status in iyh
0288   40C9 CD 9C 4A        call    PRINTHL                 ; Print Status
0289   40CC DD E5           push    ix
0290   40CE E1              pop hl
0291   40CF 23              inc hl                          ; HL has AP Name
0292   40D0 CD A6 4A        call    PRINTHLINE              ; Print AP Name
0293   40D3             ESPSETUP_NEXT.1G:
0294   40D3 21 25 4E        ld  hl,MMENU_S_NEXT
0295   40D6 CD 9C 4A        call    PRINTHL                 ; Print Main Menu
0296   40D9             MM_CURSOR_BLINK:
0297   40D9 CD 1A 41        call    MM_CURSOR_SW            ; Cursor On
0298   40DC             CONN_CHG_LOOP:
0299   40DC CD 9C 00        call    CHSNS
0300   40DF 20 13           jr  nz,MM_WAIT_INPUT            ; If not zero, there is a key in buffer
0301   40E1                 ; Ok, there is not, we can check if connection status changed
0302   40E1 CD 2E 41        call    GET_AP_STAT
0303   40E4 CA DC 40        jp  z,CONN_CHG_LOOP             ; Won't block in case of error
0304   40E7                 ; Success, so connection state is in IX+0
0305   40E7 DD 7E 00        ld  a,(ix+0)
0306   40EA FD BC           cp  iyh                         ; If same, zero
0307   40EC 28 EE           jr  z,CONN_CHG_LOOP             ; Keep loop
0308   40EE CD 1A 41        call    MM_CURSOR_SW            ; Cursor Off
0309   40F1 C3 89 40        jp  ESPSETUP_NEXT               ; Changed, re-build menu
0310   40F4             MM_WAIT_INPUT:
0311   40F4 CD 9F 00        call    CHGET
0312   40F7 FE 1B           cp  #1b                         ; ESC?
0313   40F9 CA 29 40        jp  z,ESPSETUP.EXIT             ; When done, resume initialization
0314   40FC FE 31           cp  '1'                         ; Setup Nagle?
0315   40FE CA F7 46        jp  z,SET_NAGLE
0316   4101 FE 32           cp  '2'                         ; Setup Wi-Fi On Period?
0317   4103 CA 36 46        jp  z,SET_WIFI_TIMEOUT
0318   4106 FE 33           cp  '3'                         ; Scan networks?
0319   4108 CA 8B 43        jp  z,START_WIFI_SCAN
0320   410B FE 34           cp  '4'                         ; Automatic Setting of Clock?
0321   410D CA AC 41        jp  z,START_CLK_AUTO
0322   4110 CD C0 00        call    BEEP                    ; Wrong Input, beep
0323   4113 CD 1A 41        call    MM_CURSOR_SW            ; Cursor Off
0324   4116 76              halt
0325   4117 C3 D9 40        jp  MM_CURSOR_BLINK             ; And return, waiting another key
0326   411A             MM_CURSOR_SW:                       ; Cursor workaround for CONN_CHG_LOOP
0327   411A 3E 1D           ld  a,GOLEFT
0328   411C CD A2 00        call    CHPUT
0329   411F 3E 01           ld  a,1
0330   4121 32 A9 FC        ld  (CSRSW),a
0331   4124 3E 20           ld  a,' '
0332   4126 CD A2 00        call    CHPUT                   ; Switch the cursor display mode
0333   4129 AF              xor a
0334   412A 32 A9 FC        ld  (CSRSW),a
0335   412D C9              ret
0336   412E             GET_AP_STAT:                        ; Use 'call GET_AP_STAT'
0337   412E                 CLEAR_UART
0337   412E 3E 14       >    ld  a,20
0337   4130 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0338   4133 3E 67           ld  a,CMD_AP_STS
0339   4135                 SEND_DATA                       ; Get AP conn status and name
0339   4135 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0340   4138 21 3C 00        ld  hl,60                       ; Wait Up To 1s
0341   413B ED 5B 76 F6     ld  de,(TXTTAB)                 ; We will borrow Basic Program memory area for now...
0342   413F DD 6B           ld  ixl,e
0343   4141 DD 62           ld  ixh,d                       ; Address in IX
0344   4143 C3 74 49        jp  WAIT_MENU_CMD_RESPONSE
0345   4146             
0346   4146             CONFIG_ESP_NOT_FOUND:
0347   4146 78              ld  a,b
0348   4147 B7              or  a
0349   4148 21 89 57        ld  hl,FAIL_S                   ; If 0, non responsive
0350   414B 28 03           jr  z,CONFIG_ESP_NOT_FOUND_MSG
0351   414D 21 D7 57        ld  hl,FAIL_F                   ; Otherwise, firmware is old
0352   4150             CONFIG_ESP_NOT_FOUND_MSG:
0353   4150 CD 9C 4A        call    PRINTHL
0354   4153 3E B4           ld  a,180                       ; 3s
0355   4155 CD 0F 48        call    WAIT_BEFORE_CONTINUING
0356   4158 C3 2E 40        jp  CONFIG_RETURN_TO_EXPLORER
0357   415B             
0358   415B             ;============================
0359   415B             ;===  SETUP Menu Routines  ==
0360   415B             ;===  Wi-Fi and Clock Menu ==
0361   415B             ;============================
0362   415B             CLK_MSX1_GO:
0363   415B 21 0C 50        ld  hl,MMENU_CLOCK_MSX1
0364   415E CD 9C 4A        call    PRINTHL                 ; Print Main Clock MSX1 message
0365   4161 CD 14 48        call    ISCLKAUTO
0366   4164 DD 7E 00        ld  a,(ix+0)                    ; Auto Clock Current setting
0367   4167 FE 03           cp  3                           ; If 3 adapter disabled
0368   4169 28 08           jr  z,CLK_MSX1_ADAPTERDIS
0369   416B 21 98 50        ld  hl,MMENU_CLOCK_0
0370   416E CD 9C 4A        call    PRINTHL
0371   4171 18 06           jr  CLK_MSX1_OPT
0372   4173             CLK_MSX1_ADAPTERDIS:
0373   4173 21 DE 50        ld  hl,MMENU_CLOCK_3
0374   4176 CD 9C 4A        call    PRINTHL
0375   4179             CLK_MSX1_OPT:
0376   4179 21 F1 50        ld  hl,MMENU_CLOCK_OPT
0377   417C CD 9C 4A        call    PRINTHL
0378   417F             CLK_MSX1_WAIT_OPT_INPUT:
0379   417F CD 9F 00        call    CHGET
0380   4182 FE 1B           cp  #1b                         ; ESC?
0381   4184 CA 61 40        jp  z,ESPSETUP                  ; Back to main menu
0382   4187 FE 30           cp  '0'
0383   4189 CA 97 41        jp  z,CLK_MSX1_SEND_CMD
0384   418C FE 33           cp  '3'
0385   418E CA 4E 42        jp  z,CLK_AUTO_WAIT_GMT
0386   4191 CD C0 00        call    BEEP                    ; Wrong Input, beep
0387   4194 C3 7F 41        jp  CLK_MSX1_WAIT_OPT_INPUT     ; And return, waiting another key
0388   4197             CLK_MSX1_SEND_CMD:
0389   4197 CD A2 00        call    CHPUT                   ; Print option
0390   419A D6 30           sub '0'                         ; Adjust format
0391   419C DD 77 00        ld  (ix+0),a                    ; Save it
0392   419F 3E 0D           ld  a,#0d
0393   41A1 CD A2 00        call    CHPUT
0394   41A4 3E 0A           ld  a,#0a
0395   41A6 CD A2 00        call    CHPUT
0396   41A9 C3 45 43        jp  CLK_AUTO_GMT_CHK_DONE       ; And sending the command will be done there
0397   41AC             
0398   41AC             START_CLK_AUTO:
0399   41AC CD 0D 48        call    WAIT_250MS_AND_THEN_CONTINUE
0400   41AF 3A 2D 00        ld  a,(#002D)                   ; Check MSX Version
0401   41B2 B7              or  a
0402   41B3 CA 5B 41        jp  z,CLK_MSX1_GO               ; If zero, MSX1, so can just enable or disable adapter
0403   41B6             CLK_AUTO_GO:
0404   41B6 21 B4 4E        ld  hl,MMENU_CLOCK_MSX2
0405   41B9 CD 9C 4A        call    PRINTHL                 ; Print Main Clock MSX2 message
0406   41BC CD 14 48        call    ISCLKAUTO
0407   41BF DD 7E 00        ld  a,(ix+0)                    ; Auto Clock Current setting
0408   41C2 B7              or  a                           ; If zero, off
0409   41C3 20 08           jr  nz,CLK_AUTO_CHK1
0410   41C5 21 98 50        ld  hl,MMENU_CLOCK_0
0411   41C8 CD 9C 4A        call    PRINTHL
0412   41CB 18 59           jr  CLK_AUTO_GMT_OPT
0413   41CD             CLK_AUTO_CHK1:
0414   41CD 3D              dec a                           ; If 1, on and keep wifi on
0415   41CE 20 08           jr  nz,CLK_AUTO_CHK2
0416   41D0 21 AA 50        ld  hl,MMENU_CLOCK_1
0417   41D3 CD 9C 4A        call    PRINTHL
0418   41D6 18 13           jr  CLK_AUTO_GMT
0419   41D8             CLK_AUTO_CHK2:
0420   41D8 3D              dec a                           ; If 2, on and turn wifi off
0421   41D9 20 08           jr  nz,CLK_AUTO_3
0422   41DB 21 C4 50        ld  hl,MMENU_CLOCK_2
0423   41DE CD 9C 4A        call    PRINTHL
0424   41E1 18 08           jr  CLK_AUTO_GMT
0425   41E3             CLK_AUTO_3:
0426   41E3 21 DE 50        ld  hl,MMENU_CLOCK_3
0427   41E6 CD 9C 4A        call    PRINTHL
0428   41E9 18 3B           jr  CLK_AUTO_GMT_OPT
0429   41EB             CLK_AUTO_GMT:
0430   41EB DD 66 01        ld  h,(ix+1)                    ; Save it for now
0431   41EE DD 7E 01        ld  a,(ix+1)                    ; GMT current setting
0432   41F1 CB 7F           bit 7,a                         ; If set, is -
0433   41F3 28 0B           jr  z,CLK_AUTO_GMTP
0434   41F5 3E 2D           ld  a,'-'
0435   41F7 CD A2 00        call    CHPUT
0436   41FA DD CB 01 BE     res 7,(ix+1)                    ; Clear - indicator
0437   41FE 18 05           jr  CLK_AUTO_GMTM
0438   4200             CLK_AUTO_GMTP:
