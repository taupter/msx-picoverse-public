1738   4A9E C8              ret z                           ; When string is finished, done!
1739   4A9F CD A2 00        call    CHPUT
1740   4AA2 23              inc hl
1741   4AA3 C3 9C 4A        jp  PRINTHL
1742   4AA6             
1743   4AA6             ; Routine to print the string addressed by HL on a line, if exceeding it, ends with ..
1744   4AA6             PRINTHLINE:
