1842   4B21 18 D7           jr  WRFE_LOOP
1843   4B23             WRFE_RET_OK:
1844   4B23 E1              pop hl
1845   4B24 AF              xor a
1846   4B25 C9              ret
1847   4B26             WRFE_RET_ERROR:
