1351   487E             ; Check what is the current TIMEOUT setting, return 0 if always on, otherwise there is a timeout
1352   487E             ; Will return a zero terminated string @ HL that can be printed
1353   487E             ; Will return the value in DE
1354   487E             CHECKTIMEOUT:
1355   487E                 CLEAR_UART
1355   487E 3E 14       >    ld  a,20
1355   4880 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
