1779   4ADD             WRFE_WAIT_DATA:
1780   4ADD                 LOAD_STS_PORT_IN_A
1780   4ADD 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
1781   4AE0 CB 6F           bit 5,a                         ; If nz Port #07 is not available
1782   4AE2 20 06           jr  nz,WRFE_STS_NOT_AVAILABLE
1783   4AE4 CB 47           bit 0,a                         ; if nz has data
1784   4AE6 C0              ret nz
1785   4AE7 1B              dec de
1786   4AE8 76              halt
1787   4AE9 C9              ret
1788   4AEA             WRFE_STS_NOT_AVAILABLE:
1789   4AEA 11 00 00        ld  de,0
1790   4AED AF              xor a
1791   4AEE C9              ret
