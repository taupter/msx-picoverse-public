1801   4AF5             WAIT_RESPONSE_FROM_ESP:
1802   4AF5 4F              ld  c,a                         ; Response size in C
1803   4AF6 E5              push    hl                      ; Save HL
1804   4AF7 AF              xor a
1805   4AF8             WRFE_ST1:
1806   4AF8 DD 67           ld  ixh,a                       ; We start at index 0
1807   4AFA             
1808   4AFA             WRFE_LOOP:
1809   4AFA CD DD 4A        call    WRFE_WAIT_DATA
1810   4AFD 20 07           jr  nz,WRFE_LOOP.1
1811   4AFF 7B              ld  a,e
1812   4B00 B2              or  d
1813   4B01 CA 26 4B        jp  z,WRFE_RET_ERROR
1814   4B04 18 F4           jr  WRFE_LOOP
1815   4B06             WRFE_LOOP.1:
1816   4B06                 ; nz, check the data
1817   4B06                 RECEIVE_DATA
1817   4B06 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
1818   4B09                 ; Ok, now the byte is in A, let's compare
1819   4B09             WRFE_IDXCMD:
1820   4B09 CD EF 4A        call WRFE_COMPARE
1821   4B0C                 ; if match
1822   4B0C 28 0C           jr  z,WRFE_RSP_MATCH
1823   4B0E                 ; did not match, let's zero the rsp index
1824   4B0E 1B              dec de
1825   4B0F 7B              ld  a,e
1826   4B10 B2              or  d
1827   4B11 28 13           jr  z,WRFE_RET_ERROR
1828   4B13 AF              xor a
1829   4B14 DD 67           ld  ixh,a                       ; re-start at index 0
1830   4B16 E1              pop hl                          ; restore the response index
1831   4B17 E5              push    hl                      ; and keep it in stack
1832   4B18                 ; back to get another byte
1833   4B18 18 E0           jr  WRFE_LOOP
1834   4B1A             WRFE_RSP_MATCH:
1835   4B1A                 ; match
1836   4B1A DD 24           inc ixh
1837   4B1C DD 7C           ld  a,ixh
