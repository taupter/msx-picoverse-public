3704   5405             ;========================
3705   5405             ;===  TCPIP_TCP_OPEN  ===
3706   5405             ;========================
3707   5405             ;Open a TCP connection.
3708   5405             ;
3709   5405             ;Input:  A  = 13
3710   5405             ;        HL = Address of parameters block
3711   5405             ;Output: A = Error code
3712   5405             ;        B = Connection number
3713   5405             ;        C = Connection not open reason (mostly for TLS)
3714   5405             ;
3715   5405             ;Parameters block format:
3716   5405             ;
3717   5405             ;+0 (4): Remote IP address (0.0.0.0 for unspecified remote socket)
3718   5405             ;+4 (2): Remote port (ignored if unspecified remote socket)
3719   5405             ;+6 (2): Local port, 0FFFFh for a random value
3720   5405             ;+8 (2): Suggestion for user timeout value
3721   5405             ;+10 (1): Flags:
3722   5405             ;         bit 0: Set for passive connection
3723   5405             ;         bit 1: Set for resident connection
3724   5405             ;         bit 2: Set for TLS connection
3725   5405             ;         bit 3: Set for TLS connection validating host certificate
3726   5405             ;+11 (2): If 0000 no host name validation, otherwise the hostname string address (zero terminated)
3727   5405             ;TCP_OPEN_IP1               (ix+0)
3728   5405             ;TCP_OPEN_IP2               (ix+1)
3729   5405             ;TCP_OPEN_IP3               (ix+2)
3730   5405             ;TCP_OPEN_IP4               (ix+3)
3731   5405             ;TCP_OPEN_RP                (ix+4)
3732   5405             ;TCP_OPEN_LP                (ix+6)
3733   5405             ;TCP_OPEN_TO                (ix+8)
3734   5405             ;TCP_OPEN_CMD_FLAGS         (ix+10)
3735   5405             ;TCP_OPEN_CMD_HOST_LSB      (ix+11)
3736   5405             ;TCP_OPEN_CMD_HOST_MSB      (ix+12)
3737   5405             
3738   5405             ; When no connection, let's get the reason and put in register C, as agreed
3739   5405             ; with Nestor this will be the way to go in the next UNAPI revision
3740   5405             TCPIP_TCP_OPEN_ERROR:
3741   5405                 ; next two bytes are return code and size bytes, don't care, it is 1, conn close reason
3742   5405 47              ld  b,a                         ; save error in b
3743   5406 0E 02           ld  c,2
3744   5408             TCPIP_TCP_OPEN_ERROR2:
3745   5408                 CHECK_DATA
3745   5408 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
3745   540B CB 47       >    bit 0,a                         ; If nz has data
3746   540D 20 05           jr  nz,TCPIP_TCP_OPEN_ERROR2.1
3747   540F CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
3748   5412 18 F4           jr  TCPIP_TCP_OPEN_ERROR2
3749   5414             TCPIP_TCP_OPEN_ERROR2.1:
3750   5414                 ; nz, discard
3751   5414                 RECEIVE_DATA
3751   5414 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
3752   5417 0D              dec c
3753   5418 20 EE           jr  nz,TCPIP_TCP_OPEN_ERROR2
