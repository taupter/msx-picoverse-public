3755   541B FE 0B           cp  ERR_NO_CONN
3756   541D 20 10           jr  nz,TCPIP_TCP_OPEN_ERROR4    ; other errors do not have extra bytes as result
3757   541F             ; now just get the 1 byte, close reason, should go to C
3758   541F             TCPIP_TCP_OPEN_ERROR3:
3759   541F                 CHECK_DATA
3759   541F 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
3759   5422 CB 47       >    bit 0,a                         ; If nz has data
3760   5424 20 05           jr  nz,TCPIP_TCP_OPEN_ERROR3.1
