4404   576F             ;=======================
4405   576F             ;===  TCPIP_TCP_RCV  ===
4406   576F             ;=======================
4407   576F             ;Receive data from a TCP connection.
4408   576F             ;
4409   576F             ;Input:   A  = 18
4410   576F             ;         B  = Connection number
4411   576F             ;         DE = Address for the retrieved data
4412   576F             ;         HL = Length of the data to be obtained
4413   576F             ;Output:  A  = Error code
4414   576F             ;         BC = Total number of bytes that have been actually retrieved
4415   576F             ;         HL = Number of urgent data bytes that have been retrieved
4416   576F             ;              (placed at the beginning of the received data block)
4417   576F             ; Save registers other than AF
4418   576F             TCPIP_TCP_RCV_CHECK_TIME_OUT:
4419   576F C5              push bc
4420   5770 D5              push de
4421   5771 E5              push hl
4422   5772 CD F8 59        call    GETCOUNTER
4423   5775 7D              ld  a,l
4424   5776 B4              or  h
4425   5777                 ; Restore registers, we are returning
4426   5777 E1              pop hl
4427   5778 D1              pop de
4428   5779 C1              pop bc
4429   577A C0              ret nz
4430   577B                 ; Ok, timeout...
4431   577B F1              pop af                          ; Get return address of who called this out of the stack, we will return from the function or re-start
4432   577C             TCPIP_TCP_RCV_RETRY_QRCV:
4433   577C CD 17 5A        call    GETBYTE
4434   577F B7              or  a
4435   5780 28 0C           jr  z,TCPIP_TCP_RCV_CHECK_TIME_OUT.NORXRETRY
4436   5782                 ; Ok, so let's ask ESP to re-send the data and retry receiving it
4437   5782 3D              dec a
4438   5783 CD 29 5A        call    SETBYTE                 ; we are retrying it
4439   5786 3E 72           ld  a,'r'                       ; retry transmission command
4440   5788                 SEND_DATA
4440   5788 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4441   578B C3 D2 57        jp  TCPIP_TCP_RCV.RXRETRY       ; and retry it
4442   578E             TCPIP_TCP_RCV_CHECK_TIME_OUT.NORXRETRY:
4443   578E 3E 0F           ld  a,ERR_INV_OPER
4444   5790 C9              ret                             ; and return the function itself
4445   5791             
4446   5791             TCPIP_TCP_RCV_RET_ERR:
4447   5791                 ; next two bytes are size bytes, don't care
4448   5791 47              ld  b,a                         ; save error in b
4449   5792 0E 02           ld  c,2
4450   5794             TCPIP_TCP_RCV_RET_ERR2:
4451   5794                 CHECK_DATA
4451   5794 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
4451   5797 CB 47       >    bit 0,a                         ; If nz has data
4452   5799 20 05           jr  nz,TCPIP_TCP_RCV_RET_ERR2.1
4453   579B CD 6F 57        call    TCPIP_TCP_RCV_CHECK_TIME_OUT
4454   579E 18 F4           jr  TCPIP_TCP_RCV_RET_ERR2
4455   57A0             TCPIP_TCP_RCV_RET_ERR2.1:
4456   57A0                 ; nz, discard
4457   57A0                 RECEIVE_DATA
4457   57A0 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
4458   57A3 0D              dec c
4459   57A4 20 EE           jr  nz,TCPIP_TCP_RCV_RET_ERR2
4460   57A6                 ; now return w/ error that is saved in b
4461   57A6 78              ld  a,b
