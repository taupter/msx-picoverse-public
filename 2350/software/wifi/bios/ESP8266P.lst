5209   5AC4             ;--- Restores HL copy saved in high memory
5210   5AC4             ;    Input:  none
5211   5AC4             ;    Output: HL
5212   5AC4             ;    Modifies: AF
5213   5AC4             
5214   5AC4             HLRESTORE:
5215   5AC4 C5              push    bc
5216   5AC5 D5              push    de
5217   5AC6 CD 67 59        call    GETSLT
5218   5AC9                 ; Slot in A, now get the address of our counter
5219   5AC9 CD F0 59        call    GETMEMPOINTER
5220   5ACC                 ; HL has the address of our memory area, param is 7 bytes after start
5221   5ACC 11 11 00        ld  de,MEMORY_HLBACKUP_OFFSET
5222   5ACF 19              add hl,de
5223   5AD0                 ; Ok, this is where our param is so get it
5224   5AD0 5E              ld  e,(hl)
5225   5AD1 23              inc hl
5226   5AD2 56              ld  d,(hl)
5227   5AD3 EB              ex  de,hl
5228   5AD4 D1              pop de
5229   5AD5 C1              pop bc
5230   5AD6 C9              ret
5231   5AD7             
5232   5AD7             ;--- Backups HL in high memory
5233   5AD7             ;    Input:  HL
5234   5AD7             ;    Output: none
5235   5AD7             ;    Modifies: AF
5236   5AD7             
5237   5AD7             HLBACKUP:
5238   5AD7 D5              push    de
5239   5AD8 C5              push    bc
5240   5AD9 E5              push    hl
5241   5ADA CD 67 59        call    GETSLT
5242   5ADD                 ; Slot in A, now get the address
5243   5ADD CD F0 59        call    GETMEMPOINTER
5244   5AE0                 ; HL has the address of our memory area, byte param is 7 bytes after start
5245   5AE0 11 11 00        ld  de,MEMORY_HLBACKUP_OFFSET
5246   5AE3 19              add hl,de
5247   5AE4                 ; HL has the address of param
5248   5AE4 D1              pop de                          ; Restore HL in de
5249   5AE5 73              ld  (hl),e
5250   5AE6 23              inc hl
5251   5AE7 72              ld  (hl),d
5252   5AE8 EB              ex  de,hl                       ; Restore HL
5253   5AE9 C1              pop bc                          ; Restore BC
5254   5AEA D1              pop de                          ; Restore DE
5255   5AEB C9              ret
5256   5AEC             
5257   5AEC             ;--- Obtain if DNS is ready saved in high memory
5258   5AEC             ;    Input:  none
5259   5AEC             ;    Output: A = DNS ready value
5260   5AEC             ;    Modifies: AF
5261   5AEC             
5262   5AEC             GETDNSREADY:
5263   5AEC C5              push    bc
5264   5AED D5              push    de
5265   5AEE E5              push    hl
5266   5AEF CD 67 59        call    GETSLT
5267   5AF2                 ; Slot in A, now get the address
5268   5AF2 CD F0 59        call    GETMEMPOINTER
5269   5AF5                 ; HL has the address of our memory area, DNS ready is 8 bytes after start
5270   5AF5 11 08 00        ld  de,MEMORY_DNS_READY_OFFSET
5271   5AF8 19              add hl,de
5272   5AF9                 ; Ok, get it
5273   5AF9 7E              ld  a,(hl)
5274   5AFA E1              pop hl
5275   5AFB D1              pop de
5276   5AFC C1              pop bc
5277   5AFD C9              ret
5278   5AFE             
5279   5AFE             ;--- Set DNS redy in high memory
5280   5AFE             ;    Input:  A = new value
5281   5AFE             ;    Output: none
5282   5AFE             ;    Modifies: AF
5283   5AFE             
5284   5AFE             SETDNSREADY:
5285   5AFE C5              push    bc
5286   5AFF D5              push    de
5287   5B00 E5              push    hl
5288   5B01 F5              push    af                      ; Save parameter
5289   5B02 CD 67 59        call    GETSLT
5290   5B05                 ; Slot in A, now get the address
5291   5B05 CD F0 59        call    GETMEMPOINTER
5292   5B08                 ; HL has the address of our memory area, DNS ready is 8 bytes after start
5293   5B08 11 08 00        ld  de,MEMORY_DNS_READY_OFFSET
5294   5B0B 19              add hl,de
5295   5B0C                 ; HL has the address of DNS ready
5296   5B0C F1              pop af                          ; Restore parameter
5297   5B0D 77              ld  (hl),a
5298   5B0E E1              pop hl
5299   5B0F D1              pop de
5300   5B10 C1              pop bc
5301   5B11 C9              ret
5302   5B12             
5303   5B12             ;--- Obtain DNS result saved in high memory
5304   5B12             ;    Input:  none
5305   5B12             ;    Output: HL DE = DNS result
5306   5B12             ;    Modifies: AF
5307   5B12             
5308   5B12             GETDNSRESULT:
5309   5B12 C5              push    bc
5310   5B13 CD 67 59        call    GETSLT
5311   5B16                 ; Slot in A, now get the address
5312   5B16 CD F0 59        call    GETMEMPOINTER
5313   5B19                 ; HL has the address of our memory area, DNS result is 9 bytes after start
5314   5B19 11 09 00        ld  de,MEMORY_DNS_RES_OFFSET
5315   5B1C 19              add hl,de
5316   5B1D                 ; Ok, get it, first bytes are hl
5317   5B1D 5E              ld  e,(hl)
5318   5B1E 23              inc hl
5319   5B1F 56              ld  d,(hl)
5320   5B20 D5              push    de                      ; for now, save in stack, so we can restore to HL later
5321   5B21 23              inc hl
5322   5B22 5E              ld  e,(hl)
5323   5B23 23              inc hl
5324   5B24 56              ld  d,(hl)
5325   5B25 E1              pop hl                          ; and now restore HL value from stack
5326   5B26 C1              pop bc
5327   5B27 C9              ret
5328   5B28             
5329   5B28             ;--- Set DNS result in high memory
5330   5B28             ;    Input:  HL DE = new value
5331   5B28             ;    Output: none
5332   5B28             ;    Modifies: AF
5333   5B28             
5334   5B28             SETDNSRESULT:
5335   5B28 C5              push    bc
5336   5B29 D5              push    de
5337   5B2A E5              push    hl
5338   5B2B CD 67 59        call    GETSLT
5339   5B2E                 ; Slot in A, now get the address
5340   5B2E CD F0 59        call    GETMEMPOINTER
5341   5B31                 ; HL has the address of our memory area, DNS result is 9 bytes after start
5342   5B31 11 09 00        ld  de,MEMORY_DNS_RES_OFFSET
5343   5B34 19              add hl,de
5344   5B35                 ; HL has the address of DNS result
5345   5B35 C1              pop bc                          ; Restore parameter HL in BC
5346   5B36 71              ld  (hl),c
5347   5B37 23              inc hl
5348   5B38 70              ld  (hl),b
5349   5B39 D1              pop de                          ; Restore parameter DE in DE
5350   5B3A 23              inc hl
5351   5B3B 73              ld  (hl),e
5352   5B3C 23              inc hl
5353   5B3D 72              ld  (hl),d
5354   5B3E 69              ld  l,c
5355   5B3F 60              ld  h,b                         ; And HL is restored
5356   5B40 C1              pop bc                          ; Restore BC
5357   5B41 C9              ret
5358   5B42             
5359   5B42             ;--- Convert a character to upper-case if it is a lower-case letter
5360   5B42             TOUPPER:
5361   5B42 FE 61           cp  "a"
5362   5B44 D8              ret c
5363   5B45 FE 7B           cp  "z"+1
5364   5B47 D0              ret nc
5365   5B48 E6 DF           and #DF
5366   5B4A C9              ret
5367   5B4B             
5368   5B4B             ;*********************************************
5369   5B4B             ;***       WAIT_RESPONSE_FROM_ESP          ***
5370   5B4B             ;*** Will wait ESP to send a response,     ***
5371   5B4B             ;*** discarding all data until it is found.***
5372   5B4B             ;***                                       ***
5373   5B4B             ;*** Inputs:                               ***
5374   5B4B             ;*** HL - Expected response string         ***
5375   5B4B             ;*** A - Response Size                     ***
5376   5B4B             ;*** DE - TimeOut in ticks                 ***
5377   5B4B             ;***                                       ***
5378   5B4B             ;*** Output:                               ***
5379   5B4B             ;*** A - 0 if response received            ***
5380   5B4B             ;*** otherwise response not received and   ***
5381   5B4B             ;*** timed-out.                            ***
5382   5B4B             ;***                                       ***
5383   5B4B             ;*** Changes HL, BC, AF, DE, IX            ***
5384   5B4B             ;*********************************************
5385   5B4B             WRFE_WAIT_DATA:
5386   5B4B                 LOAD_STS_PORT_IN_A
5386   5B4B 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
5387   5B4E CB 6F           bit 5,a                         ; If nz Port #07 is not available
5388   5B50 20 06           jr  nz,WRFE_STS_NOT_AVAILABLE
5389   5B52 CB 47           bit 0,a                         ; if nz has data
5390   5B54 C0              ret nz
5391   5B55 1B              dec de
5392   5B56 76              halt
5393   5B57 C9              ret
5394   5B58             WRFE_STS_NOT_AVAILABLE:
5395   5B58 11 00 00        ld  de,0
5396   5B5B AF              xor a
5397   5B5C C9              ret
5398   5B5D             
5399   5B5D             WRFE_COMPARE:
5400   5B5D 47              ld  b,a
5401   5B5E 7E              ld  a,(hl)
5402   5B5F B8              cp  b
5403   5B60 C0              ret nz
5404   5B61 23              inc hl
5405   5B62 C9              ret
5406   5B63             
5407   5B63             WAIT_RESPONSE_FROM_ESP:
5408   5B63 4F              ld  c,a                         ; Response size in C
5409   5B64 E5              push    hl                      ; Save HL
5410   5B65 AF              xor a
5411   5B66             WRFE_ST1:
5412   5B66 DD 67           ld  ixh,a                       ; We start at index 0
5413   5B68             
5414   5B68             WRFE_LOOP:
5415   5B68 CD 4B 5B        call    WRFE_WAIT_DATA
5416   5B6B 20 07           jr  nz,WRFE_LOOP.1
5417   5B6D 7B              ld  a,e
5418   5B6E B2              or  d
5419   5B6F CA 94 5B        jp  z,WRFE_RET_ERROR
5420   5B72 18 F4           jr  WRFE_LOOP
5421   5B74             WRFE_LOOP.1:
5422   5B74                 ; nz, check the data
5423   5B74                 RECEIVE_DATA
5423   5B74 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
5424   5B77                 ; Ok, now the byte is in A, let's compare
5425   5B77             WRFE_IDXCMD:
5426   5B77 CD 5D 5B        call WRFE_COMPARE
5427   5B7A                 ; if match
5428   5B7A 28 0C           jr  z,WRFE_RSP_MATCH
5429   5B7C                 ; did not match, let's zero the rsp index
5430   5B7C 1B              dec de
5431   5B7D 7B              ld  a,e
5432   5B7E B2              or  d
5433   5B7F 28 13           jr  z,WRFE_RET_ERROR
5434   5B81 AF              xor a
5435   5B82 DD 67           ld  ixh,a                       ; re-start at index 0
5436   5B84 E1              pop hl                          ; restore the response index
5437   5B85 E5              push    hl                      ; and keep it in stack
5438   5B86                 ; back to get another byte
5439   5B86 18 E0           jr  WRFE_LOOP
5440   5B88             WRFE_RSP_MATCH:
5441   5B88                 ; match
5442   5B88 DD 24           inc ixh
5443   5B8A DD 7C           ld  a,ixh
5444   5B8C B9              cp  c
5445   5B8D                 ; if a = c done and response is success
5446   5B8D 28 02           jr  z,WRFE_RET_OK
5447   5B8F                 ; not done, back to get more bytes
5448   5B8F 18 D7           jr  WRFE_LOOP
5449   5B91             WRFE_RET_OK:
5450   5B91 E1              pop hl
5451   5B92 AF              xor a
5452   5B93 C9              ret
5453   5B94             WRFE_RET_ERROR:
5454   5B94 E1              pop hl
5455   5B95 3E 01           ld  a,1
5456   5B97 C9              ret
5457   5B98             
5458   5B98             ;*********************************************
5459   5B98             ;***              RESET ESP                ***
5460   5B98             ;*** If RESET ok, A will be 0, otherwise   ***
5461   5B98             ;*** failure                               ***
5462   5B98             ;*********************************************
5463   5B98             RESET_ESP:
5464   5B98                 ; Is ESP installed?
5465   5B98                 CLEAR_UART                      ; Clear UART
5465   5B98 3E 14       >    ld  a,20
5465   5B9A 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
5466   5B9D 3E 51           ld  a,'Q'
5467   5B9F CD A2 00        call    CHPUT
5468   5BA2 3E 3F           ld  a,CMD_QUERY_ESP
5469   5BA4                 SEND_DATA
5469   5BA4 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
5470   5BA7 3E 71           ld  a,'q'
5471   5BA9 CD A2 00        call    CHPUT
5472   5BAC 21 9F 5D        ld  hl,RSP_CMD_QUERY_ESP        ; Expected response
5473   5BAF 11 3C 00        ld  de,60                       ; Up to 1s @ 60Hz
5474   5BB2 3E 02           ld  a,RSP_CMD_QUERY_ESP_SIZE    ; Size of response
5475   5BB4 CD 63 5B        call    WAIT_RESPONSE_FROM_ESP
5476   5BB7 B7              or  a
5477   5BB8 3E 01           ld  a,1
5478   5BBA 28 0B           jr  z,RESET_ESP_INIT            ; ESP Found
5479   5BBC 3E 58           ld  a,'X'
5480   5BBE CD A2 00        call    CHPUT
5481   5BC1 CD 13 5C        call    SCAN_ESP_QUERY_SPEED
5482   5BC4 06 00           ld  b,0                         ; 0 if no response
5483   5BC6 C9              ret
5484   5BC7             RESET_ESP_INIT:
5485   5BC7 3E 49           ld  a,'I'
5486   5BC9 CD A2 00        call    CHPUT
5487   5BCC 06 03           ld  b,3                         ; Retry up to 10 times
5488   5BCE             RESET_ESP_LOOP:
5489   5BCE                 CLEAR_UART
5489   5BCE 3E 14       >    ld  a,20
5489   5BD0 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
5490   5BD3 3E 52           ld  a,'R'
5491   5BD5 CD A2 00        call    CHPUT
5492   5BD8                 SET_SPEED
5492   5BD8 AF          >    xor a
5492   5BD9 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
5493   5BDC 3E 53           ld  a,'S'
5494   5BDE CD A2 00        call    CHPUT
5495   5BE1 76              halt
5496   5BE2 76              halt                            ; Wait a little to make sure speed is adjusted
5497   5BE3 3E 57           ld  a,CMD_WRESET_ESP
5498   5BE5                 SEND_DATA
5498   5BE5 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
5499   5BE8 3E 57           ld  a,'W'
5500   5BEA CD A2 00        call    CHPUT
5501   5BED 21 9A 5D        ld  hl,RSP_CMD_RESET_ESP        ; Expected response
5502   5BF0 11 5A 00        ld  de,90                       ; Up to 1.5s @ 60Hz
5503   5BF3 3E 05           ld  a,RSP_CMD_RESET_ESP_SIZE    ; Size of response
5504   5BF5 C5              push    bc                      ; Save retry counter
5505   5BF6 CD 63 5B        call    WAIT_RESPONSE_FROM_ESP
5506   5BF9 C1              pop bc                          ; restore retry counter
5507   5BFA B7              or  a                           ; Did WAIT RESPONSE return zero?
5508   5BFB 20 07           jr  nz,RESET_ESP_LOOP_FAIL
5509   5BFD 3E 4F           ld  a,'O'
5510   5BFF CD A2 00        call    CHPUT
5511   5C02 AF              xor a                           ; A=0, success (CHPUT clobbered flags so cannot rely on ret z)
5512   5C03 C9              ret                             ; Warm Reset Ok
5513   5C04             RESET_ESP_LOOP_FAIL:
5514   5C04 3E 78           ld  a,'x'
5515   5C06 CD A2 00        call    CHPUT
5516   5C09 10 C3           djnz RESET_ESP_LOOP             ; No, decrement retry counter and let the loop check
5517   5C0B                 ; No more retries? Then check if it is old ESP FW
5518   5C0B             RESET_CHK_IF_INSTALLED:
5519   5C0B                 ; No more retries? Then it is old ESP FW
5520   5C0B 3E 46           ld  a,'F'
5521   5C0D CD A2 00        call    CHPUT
5522   5C10 06 01           ld  b,1
5523   5C12 C9              ret
5524   5C13             
5525   5C13             SCAN_ESP_QUERY_SPEED:
5526   5C13 C5              push    bc
5527   5C14 D5              push    de
5528   5C15 E5              push    hl
5529   5C16 0E 00           ld  c,0
5530   5C18 06 0A           ld  b,10
5531   5C1A             SCAN_ESP_QUERY_SPEED_LOOP:
5532   5C1A                 CLEAR_UART
5532   5C1A 3E 14       >    ld  a,20
5532   5C1C 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
5533   5C1F 79              ld  a,c
5534   5C20                 WRITE_CMD_PORT_A
5534   5C20 32 06 7F    >        ld  (MEM_OUT_CMD_PORT),a
5535   5C23 76              halt
5536   5C24 76              halt
5537   5C25 3E 3F           ld  a,CMD_QUERY_ESP
5538   5C27                 SEND_DATA
5538   5C27 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
5539   5C2A 21 9F 5D        ld  hl,RSP_CMD_QUERY_ESP
5540   5C2D 11 14 00        ld  de,20                       ; Short probe timeout per speed slot
5541   5C30 3E 02           ld  a,RSP_CMD_QUERY_ESP_SIZE
5542   5C32 CD 63 5B        call    WAIT_RESPONSE_FROM_ESP
5543   5C35 B7              or  a
5544   5C36 28 07           jr  z,SCAN_ESP_QUERY_SPEED_FOUND
5545   5C38 0C              inc c
5546   5C39 10 DF           djnz    SCAN_ESP_QUERY_SPEED_LOOP
5547   5C3B E1              pop hl
5548   5C3C D1              pop de
5549   5C3D C1              pop bc
5550   5C3E C9              ret
5551   5C3F             SCAN_ESP_QUERY_SPEED_FOUND:
5552   5C3F E1              pop hl
5553   5C40 D1              pop de
5554   5C41 C1              pop bc
5555   5C42 C9              ret
5556   5C43             
5557   5C43             ;*********************************************
5558   5C43             ;***              SET TIME                 ***
5559   5C43             ;*** H - Hour                              ***
5560   5C43             ;*** L - Minutes                           ***
5561   5C43             ;*** D - Seconds                           ***
5562   5C43             ;***                                       ***
5563   5C43             ;*** A - 0 if Ok otherwise invalid time    ***
5564   5C43             ;*********************************************
5565   5C43             SET_TIME:
5566   5C43 7C              ld  a,h                         ; Hour in A
5567   5C44 FE 18           cp  24                          ; Compare to 24
5568   5C46 30 12           jr  nc,SET_TIME_ERR             ; If 24 or more, invalid
5569   5C48 7D              ld  a,l                         ; Minutes in A
5570   5C49 FE 3C           cp  60                          ; Compare to 60
5571   5C4B 30 0D           jr  nc,SET_TIME_ERR             ; If 60 or more, invalid
5572   5C4D 7A              LD  a,d                         ; Seconds in D
5573   5C4E FE 3C           cp  60                          ; Compare to 60
5574   5C50 30 08           jr  nc,SET_TIME_ERR             ; If 60 or more invalid
5575   5C52 44              ld  b,h                         ; Hour in B
5576   5C53 4D              ld  c,l                         ; Minutes in C
5577   5C54 5A              ld  e,d                         ; Seconds in E
5578   5C55 CD 5D 5C        call    SET_RTC_TIME            ; Set time in RTC
5579   5C58 AF              xor a                           ; 0 in A
5580   5C59 C9              ret                             ; Return
5581   5C5A             ;   Invalid parameter
5582   5C5A             SET_TIME_ERR:
5583   5C5A 3E 01           ld  a,1                         ; Invalid Time
5584   5C5C C9              ret                             ; Return
5585   5C5D             
5586   5C5D             SET_RTC_TIME:
5587   5C5D 6B              ld  l,e                         ; Seconds in L
5588   5C5E 61              ld  h,c                         ; Minutes in H
5589   5C5F 50              ld  d,b                         ; Hour in D
5590   5C60 CD B8 5C        call    STOP_RTC_COUNT_SET_MODE0; Select RTC Register 13, and set Mode / Page 0
5591   5C63 3E 0F           ld  a,#F                        ; Register F
5592   5C65 D3 B4           out (#B4),a
5593   5C67 3E 02           ld  a,2
5594   5C69 D3 B5           out (#B5),a                     ; Timer reset seconds and on both clock pulses
5595   5C6B 1E 00           ld  e,0                         ; Start at register 0
5596   5C6D C3 F3 5C        jp  SET_RTC_DATE.1              ; And save L, H and D, function will return from there
5597   5C70             
5598   5C70             ;*********************************************
5599   5C70             ;***              SET DATE                 ***
5600   5C70             ;*** HL - Year from 1980 to 2079           ***
5601   5C70             ;*** D - Month from 1 to 12                ***
5602   5C70             ;*** E - Day from 1 to 31                  ***
5603   5C70             ;***                                       ***
5604   5C70             ;*** A - 0 if Ok otherwise invalid Date    ***
5605   5C70             ;*********************************************
5606   5C70             SET_DATE:
5607   5C70 01 44 F8        ld  bc,#F844
5608   5C73 09              add hl,bc
5609   5C74 30 32           jr  nc,SET_DATE_ERR             ; No carry -> Year is less than 1980, invalid date
5610   5C76 7C              ld  a,h
5611   5C77 B7              or  a
5612   5C78 20 2E           jr  nz,SET_DATE_ERR             ; If H is set, means year is greater than 2235 ,invalid
5613   5C7A 7D              ld  a,l
5614   5C7B FE 64           cp  100
5615   5C7D 30 29           jr  nc,SET_DATE_ERR             ; If L >= 100 year is greater than 2079, invalid
5616   5C7F 47              ld  b,a                         ; Year - 1980 in B
5617   5C80 7A              ld  a,d                         ; Now test month
5618   5C81 3D              dec a
5619   5C82 FE 0C           cp  12                          ; If 12 or less this should carry
5620   5C84 30 22           jr  nc,SET_DATE_ERR             ; otherwise invalid
5621   5C86 21 AB 5C        ld  hl,DAYS_IN_MONTH            ; Days in Month table
5622   5C89 85              add a,l                         ; add our month
5623   5C8A 6F              ld  l,a                         ; back in L
5624   5C8B 30 01           jr  nc,SET_DATE1                ; no carry done
5625   5C8D 24              inc h                           ; otherwise increase H
5626   5C8E             SET_DATE1:
5627   5C8E 3E 1C           ld  a,28                        ; 28 days
5628   5C90 BE              cp  (hl)                        ; If month is 28 days, February, need to check if leap and limit is 29 in this year
5629   5C91 20 08           jr  nz,SET_DATE2                ; if not, skip below code , so probably above check is if month is february
5630   5C93 78              ld  a,b                         ; Year - 1980 in A again
5631   5C94 E6 03           and 3                           ; if other than 0, non divisible per 4, so not a leap year
5632   5C96 20 03           jr  nz,SET_DATE2                ; Regular year
5633   5C98 21 B7 5C        ld  hl,DAYS_IN_FEBRUARY_LEAP    ; HL has address of 29 days, maximum number of days for february in leap year
5634   5C9B             SET_DATE2:
5635   5C9B 7B              ld  a,e                         ; Day of month in A
5636   5C9C 3D              dec a                           ; Decrement
5637   5C9D BE              cp  (hl)                        ; Compare with Days in month
5638   5C9E 30 08           jr  nc,SET_DATE_ERR             ; If day is greater than how many days in month, invalid
5639   5CA0 6B              ld  l,e                         ; Day of month in L
5640   5CA1 62              ld  h,d                         ; Month in H
5641   5CA2 50              ld  d,b                         ; Year - 1980 in D
5642   5CA3 CD DD 5C        call    SET_RTC_DATE            ; Set date in RTC
5643   5CA6 AF              xor a                           ; A = 0
5644   5CA7 C9              ret                             ; Success
5645   5CA8             ;   Invalid parameter
5646   5CA8             SET_DATE_ERR:
5647   5CA8 3E 01           ld  a,1
5648   5CAA C9              ret
5649   5CAB             
5650   5CAB             ; Table of top day value for each month
5651   5CAB             DAYS_IN_MONTH:          db  31,28,31,30,31,30,31,31,30,31,30,31
5651   5CAB 1F1C1F1E1F1E1F1F1E1F1E1F
5652   5CB7             ; And top day value in February when Leap Year
5653   5CB7 1D          DAYS_IN_FEBRUARY_LEAP:  db  29
5654   5CB8             
5655   5CB8             ; Will select Mode 00 (Date and Time page) and stop clock counting
5656   5CB8             ; Register D value will be left in A
5657   5CB8             STOP_RTC_COUNT_SET_MODE0:
5658   5CB8 3E 0D           ld  a,#D
5659   5CBA D3 B4           out (#B4),a                     ; Select RTC register D (mode)
5660   5CBC DB B5           in  a,(#B5)                     ; read register D
5661   5CBE E6 04           and 4                           ; Save Alarm EN setting, and mode register is 00 and stop counting time
5662   5CC0 D3 B5           out (#B5),a                     ; And save
5663   5CC2 C9              ret
5664   5CC3             
5665   5CC3             ; Will get a non BCD value in A, convert it to BCD and then save it in
5666   5CC3             ; a register pair that starts in the register indicated in E
5667   5CC3             ; Register E will have the next register after that register pair
5668   5CC3             RTC_SAVE_REGISTERPAIR:
5669   5CC3 4F              ld  c,a                         ; Save A in C
5670   5CC4 AF              xor a                           ; 0 in A
5671   5CC5 06 08           ld  b,8                         ; 8 in B, number of bits for conversion
5672   5CC7             RTC_SAVE_REGISTERPAIR.1:
5673   5CC7 CB 01           rlc c                           ; Leftmost bit in Carry
5674   5CC9 8F              adc a,a                         ; A = (A * 2) + Carry
5675   5CCA 27              daa                             ; decimal adjust A, shift = BCD x 2 + carry
5676   5CCB 10 FA           djnz    RTC_SAVE_REGISTERPAIR.1 ; Repeat for 8 bits
5677   5CCD CD D4 5C        call    SET_RTC_REG             ; Save LSB in register and increase register address
5678   5CD0 0F              rrca
5679   5CD1 0F              rrca
5680   5CD2 0F              rrca
5681   5CD3 0F              rrca                            ; now MSB is in LSB position
5682   5CD4             SET_RTC_REG:
5683   5CD4 47              ld  b,a                         ; save value to set in B
5684   5CD5 7B              ld  a,e                         ; and now register address in A
5685   5CD6 D3 B4           out (#B4),a                     ; The register we want to set
5686   5CD8 78              ld  a,b                         ; restore value
5687   5CD9 D3 B5           out (#B5),a                     ; save it
5688   5CDB 1C              inc e                           ; increase register address, as this usually is done in pairs
5689   5CDC C9              ret
5690   5CDD             
5691   5CDD             ; Auxiliary function for SET_DATE and SET_TIME
5692   5CDD             ; SET_RTC_DATE will save date, parameters:
5693   5CDD             ; L - Day
5694   5CDD             ; H - Month
5695   5CDD             ; D - Years since 1980
5696   5CDD             ; All values are regular values, this function will properly convert them
5697   5CDD             ;
5698   5CDD             ; SET_RTC_DATE.1 is used by SET_TIME as well
5699   5CDD             ; It will save three register pairs, starting with the register in E
5700   5CDD             ; First pair is updated with value in L
5701   5CDD             ; Second pair is updated with value in H
5702   5CDD             ; Third pair is updated with value in D
5703   5CDD             SET_RTC_DATE:
5704   5CDD CD B8 5C        call    STOP_RTC_COUNT_SET_MODE0; Select RTC Register 13, and set Mode / Page 0
5705   5CE0 F6 01           or  1                           ; Set Bit 0, so Mode / Page 1
5706   5CE2 D3 B5           out (#B5),a                     ; save it in register 13, now page 1 selected
5707   5CE4 3E 0B           ld  a,#B                        ; Leap Year Counter Register
5708   5CE6 D3 B4           out (#B4),a                     ; Select it
5709   5CE8 7A              ld  a,d                         ; Load Years in leap year counter
5710   5CE9 D3 B5           out (#B5),a                     ; So it has count of leap years (0 is 1980, leap, and every time it is 4, leap year again)
5711   5CEB CD B8 5C        call    STOP_RTC_COUNT_SET_MODE0; Select RTC Register 13 and set mode / page 0
5712   5CEE CD B8 5C        call    STOP_RTC_COUNT_SET_MODE0; do it a second time... DOS does it, don't want to JYNX it :P
5713   5CF1 1E 07           ld  e,7                         ; Register 7
5714   5CF3             SET_RTC_DATE.1:
5715   5CF3 7D              ld  a,l                         ; A has day
5716   5CF4 CD C3 5C        call    RTC_SAVE_REGISTERPAIR   ; Will convert day to BCD and save in registers 7 and 8
5717   5CF7 7C              ld  a,h                         ; A has month
5718   5CF8 CD C3 5C        call    RTC_SAVE_REGISTERPAIR   ; Will convert month to BCD and save in register 9 and A
5719   5CFB 7A              ld  a,d                         ; A has how many years since 1980
5720   5CFC CD C3 5C        call    RTC_SAVE_REGISTERPAIR   ; Will convert to BCD and save in register B and C
5721   5CFF 3E 0D           ld  a,#D                        ; Register D
5722   5D01 D3 B4           out (#B4),a                     ; Send it
5723   5D03 DB B5           in  a,(#B5)                     ; Read its value
5724   5D05 F6 08           or  8                           ; Start counting time again
5725   5D07 D3 B5           out (#B5),a                     ; Send
5726   5D09 C9              ret
5727   5D0A             
5728   5D0A             ; Pattern setup routine
5729   5D0A             PATTERN_SETUP:
5730   5D0A AF              xor a                           ; Bit-16, V9938 and V9958 only
5731   5D0B 21 88 00        ld  hl,#0088                    ; Bit-15 to 0, pattern base address = #0088
5732   5D0E CD 7E 5D        call SET_VDP_WRITE
5733   5D11 21 1E 5D        ld  hl,PATTERN_DATA             ; Point to hl
5734   5D14 06 60           ld  b,8*12                      ; Redraw 12 chars, max 12 chars are suggested
5735   5D16 0E 98           ld  c,#98                       ; port #98
5736   5D18             OUTI_TO_VRAM_TMS9918:
5737   5D18 ED A3           outi                            ; Slower than otir but useful on TMS9918 which requires 29 T-states
5738   5D1A C2 18 5D        jp  nz,OUTI_TO_VRAM_TMS9918     ; Therefore, don't use 'djnz' here!
5739   5D1D C9              ret
5740   5D1E             PATTERN_DATA:
5741   5D1E             ; Pattern-01 is CHR$(1)+CHR$(81) = SCAN_TERMINATOR_OPEN
5742   5D1E 06              db  %00000110
5743   5D1F 09              db  %00001001
5744   5D20 09              db  %00001001
5745   5D21 FC              db  %11111100                   ; "Opened Padlock"
5746   5D22 FC              db  %11111100
5747   5D23 FC              db  %11111100
5748   5D24 FC              db  %11111100
5749   5D25 00              db  %00000000
5750   5D26             ; Pattern-02 is CHR$(1)+CHR$(82) = SCAN_TERMINATOR_ENC
5751   5D26 30              db  %00110000
5752   5D27 48              db  %01001000
5753   5D28 48              db  %01001000
5754   5D29 FC              db  %11111100                   ; "Closed Padlock"
5755   5D2A FC              db  %11111100
5756   5D2B FC              db  %11111100
5757   5D2C FC              db  %11111100
5758   5D2D 00              db  %00000000
5759   5D2E             ; Pattern-03 is CHR$(1)+CHR$(83) = Wi-Fi Connected to the AP:
5760   5D2E 00              db  %00000000
5761   5D2F 00              db  %00000000
5762   5D30 70              db  %01110000
5763   5D31 70              db  %01110000                   ; "Full Access Point"
5764   5D32 70              db  %01110000
5765   5D33 20              db  %00100000
5766   5D34 20              db  %00100000
5767   5D35 70              db  %01110000
5768   5D36             ; Pattern-04 is CHR$(1)+CHR$(84) = Wi-Fi Failed to connect to:
5769   5D36 00              db  %00000000
5770   5D37 88              db  %10001000
5771   5D38 50              db  %01010000
5772   5D39 20              db  %00100000                   ; "X"
5773   5D3A 50              db  %01010000
5774   5D3B 88              db  %10001000
5775   5D3C 00              db  %00000000
5776   5D3D 00              db  %00000000
5777   5D3E             ; Pattern-05 is CHR$(1)+CHR$(85) = Requesting connection to:
5778   5D3E 00              db  %00000000
5779   5D3F 00              db  %00000000
5780   5D40 50              db  %01010000
5781   5D41 20              db  %00100000                   ; "Partial Access Point"
5782   5D42 50              db  %01010000
5783   5D43 20              db  %00100000
5784   5D44 20              db  %00100000
5785   5D45 70              db  %01110000
5786   5D46             ; Pattern-06 is CHR$(1)+CHR$(86) = Wi-Fi Did not find the AP:
5787   5D46 00              db  %00000000
5788   5D47 70              db  %01110000
5789   5D48 88              db  %10001000
5790   5D49 10              db  %00010000                   ; "?"
5791   5D4A 20              db  %00100000
5792   5D4B 00              db  %00000000
5793   5D4C 20              db  %00100000
5794   5D4D 00              db  %00000000
5795   5D4E             ; Pattern-07 is CHR$(1)+CHR$(87) = Wi-Fi is Idle, AP configured:
5796   5D4E 00              db  %00000000
5797   5D4F 00              db  %00000000
5798   5D50 00              db  %00000000
5799   5D51 20              db  %00100000                   ; "i"
5800   5D52 00              db  %00000000
5801   5D53 20              db  %00100000
5802   5D54 20              db  %00100000
5803   5D55 70              db  %01110000
5804   5D56             ; Pattern-08 is CHR$(1)+CHR$(88) = Left Middle Wave
5805   5D56 00              db  %00000000
5806   5D57 20              db  %00100000
5807   5D58 40              db  %01000000
5808   5D59 40              db  %01000000                   ; "("
5809   5D5A 40              db  %01000000
5810   5D5B 20              db  %00100000
5811   5D5C 00              db  %00000000
5812   5D5D 00              db  %00000000
5813   5D5E             ; Pattern-09 is CHR$(1)+CHR$(89) = Right Middle Wave
5814   5D5E 00              db  %00000000
5815   5D5F 20              db  %00100000
5816   5D60 10              db  %00010000
5817   5D61 10              db  %00010000                   ; ")"
5818   5D62 10              db  %00010000
5819   5D63 20              db  %00100000
5820   5D64 00              db  %00000000
5821   5D65 00              db  %00000000
5822   5D66             ; Pattern-10 is CHR$(1)+CHR$(90) = Wi-Fi is reconnecting to:
5823   5D66 00              db  %00000000
5824   5D67 00              db  %00000000
5825   5D68 00              db  %00000000
5826   5D69 A8              db  %10101000                   ; "..."
5827   5D6A 00              db  %00000000
5828   5D6B 00              db  %00000000
5829   5D6C 00              db  %00000000
5830   5D6D 00              db  %00000000
5831   5D6E             ; Pattern-11 is CHR$(1)+CHR$(91) = Double Dot
5832   5D6E 00              db  %00000000
5833   5D6F 00              db  %00000000
5834   5D70 00              db  %00000000
5835   5D71 00              db  %00000000                   ; ".."
5836   5D72 00              db  %00000000
5837   5D73 66              db  %01100110
5838   5D74 66              db  %01100110
5839   5D75 00              db  %00000000
5840   5D76             ; Pattern-12 is CHR$(1)+CHR$(92) = Copyright
5841   5D76 38              db  %00111000
5842   5D77 44              db  %01000100
5843   5D78 BA              db  %10111010
5844   5D79 A2              db  %10100010                   ; "(c)"
5845   5D7A BA              db  %10111010
5846   5D7B 44              db  %01000100
5847   5D7C 38              db  %00111000
5848   5D7D 00              db  %00000000
5849   5D7E             ; http://map.grauw.nl/articles/vdp_tut.php
5850   5D7E             ; Set VDP address counter to write from address AHL (17-bits)
5851   5D7E             ; Enables the interrupts
5852   5D7E             SET_VDP_WRITE:
5853   5D7E CB 04           rlc h
5854   5D80 17              rla
5855   5D81 CB 04           rlc h
5856   5D83 17              rla
5857   5D84 CB 3C           srl h
5858   5D86 CB 3C           srl h
5859   5D88 F3              di
5860   5D89 D3 99           out (#99),a
5861   5D8B 3E 8E           ld  a,14+128
5862   5D8D D3 99           out (#99),a
5863   5D8F 7D              ld  a,l
5864   5D90 00              nop                             ; Do not remove this 'nop' here!
5865   5D91 D3 99           out (#99),a
5866   5D93 7C              ld  a,h
5867   5D94 F6 40           or  64
5868   5D96 FB              ei
5869   5D97 D3 99           out (#99),a
5870   5D99 C9              ret
