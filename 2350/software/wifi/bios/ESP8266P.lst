2220   4CC1             ;===  HTIM_I hook execution  ===
2221   4CC1             ;===============================
2222   4CC1             DO_HTIMI:
2223   4CC1 F5              push    af                      ; HTIM hook -> need to keep A value
2224   4CC2 CD F8 59        call    GETCOUNTER              ; Counter in hl
2225   4CC5 7D              ld  a,l
