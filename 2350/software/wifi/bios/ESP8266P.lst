4754   593F 18 F4           jr  TCPIP_CONFIG_IP_RC
4755   5941             TCPIP_CONFIG_IP_RC.1:
4756   5941                 ; nz, discard
4757   5941                 RECEIVE_DATA
4757   5941 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
4758   5944 C9              ret                             ; done
