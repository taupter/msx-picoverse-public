3793   5454                 ; if TLS and next two bytes are 00 no host to check
3794   5454 28 40           jr  z,TCPIP_TCP_OPEN_NO_CHECKHOST
3795   5456                 ; we are here, host to check
3796   5456 DD 66 0C        ld  h,(ix+12)                   ; TCP_OPEN_CMD_HOST_MSB
