3372   5230 D5              push    de
3373   5231                 SEND_DATA                       ; Send the command
3373   5231 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
3374   5234                 ; prepare new data size, adding our 7 bytes overhead
3375   5234 DD 62           ld  ixh,d
3376   5236 DD 6B           ld  ixl,e
3377   5238 11 07 00        ld  de,7
3378   523B DD 6E 06        ld  l,(ix+6)
3379   523E DD 66 07        ld  h,(ix+7)
