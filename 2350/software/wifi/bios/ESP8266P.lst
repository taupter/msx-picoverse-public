0636   41F3             ;===  TPA Memory Allocation  ==
0637   41F3             ;==============================
0638   41F3             HIMEM_ALLOC:
0639   41F3                 ; Now let's reserve memory in the 4th page for our usage
0640   41F3 2A 4A FC        ld hl,(HIMEM)                   ; Get HIMEM
0641   41F6 B7              or  a                           ; Clear Carry
0642   41F7 11 1E 00        ld  de,HIMEM_RESERVED_SIZE      ; Reserve How much memory we need
0643   41FA ED 52           sbc hl,de                       ; New HIMEM
0644   41FC 22 4A FC        ld  (HIMEM),hl                  ; Save it
0645   41FF 23              inc hl                          ; To be safe
0646   4200 EB              ex  de,hl                       ; now in DE
0647   4201 CD 67 59        call    GETSLT
0648   4204 CD D4 59        call    GETMEMPOINTERADDR       ; This is where we are going to store our memory area address
0649   4207                 ; GETSLT and GETMEMPOINTER do not change DE, so it still has the our memory area address
0650   4207 73              ld  (hl),e
0651   4208 23              inc hl
0652   4209 72              ld  (hl),d                      ; And save our memory area there
0653   420A                 ; Ok, DE has our memory area, let's save old H_TIMI hook there
0654   420A 21 9F FD        ld  hl,H_TIMI                   ; The actual H_TIMI hook
0655   420D 01 05 00        ld  bc,5                        ; That is 5 bytes large
0656   4210 ED B0           ldir                            ; And move to our memory area
0657   4212 F3              di                              ; Turn of interrupts as we are going to patch H_TIMI
0658   4213             PATCH_H_TIMI:
0659   4213 3E F7           ld  a,#F7                       ; RST #30
0660   4215 32 9F FD        ld  (H_TIMI),a                  ; In H_TIMI hook
0661   4218 CD 67 59        call    GETSLT                  ; Our Slot in A
0662   421B 32 A0 FD        ld  (H_TIMI+1),a                ; Next H_TIMI hook byte
0663   421E 21 C1 4C        ld  hl,DO_HTIMI                 ; Our H_TIMI routine address
0664   4221 22 A1 FD        ld  (H_TIMI+2),hl               ; Goes to the following two bytes in the hook
0665   4224 FB              ei                              ; done, so re-enable interrupts
0666   4225             
0667   4225                 ; Set DNS_READY to zero
0668   4225 AF              xor a
0669   4226 CD FE 5A        call    SETDNSREADY
0670   4229                 ; Set TIME-OUT counter to zero
0671   4229 21 00 00        ld  hl,0
0672   422C CD 07 5A        call    SETCOUNTER
0673   422F C9              ret
