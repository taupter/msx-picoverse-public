2886   4FEA             ;=====================
2887   4FEA             ;===  TCPIP_DNS_Q  ===
2888   4FEA             ;=====================
2889   4FEA             ;Start a host name resolution query.
2890   4FEA             ;
2891   4FEA             ;Input:  A  = 6
2892   4FEA             ;        HL = Address of the host name to be resolved, zero terminated
2893   4FEA             ;        B  = Flags, when set to 1 they instruct the resolver to:
2894   4FEA             ;             bit 0: Only abort the query currently in progress, if there is any
2895   4FEA             ;                    (other flags and registers are then ignored)
2896   4FEA             ;             bit 1: Assume that the passed name is an IP address,
2897   4FEA             ;                    and return an error if this is not true
2898   4FEA             ;             bit 2: If there is a query in progress already,
2899   4FEA             ;                    do NOT abort it and return an error instead
2900   4FEA             ;Output:  A = Error code
2901   4FEA             ;         B = 0 if a query to a DNS server is in progress
2902   4FEA             ;             1 if the name represented an IP address
2903   4FEA             ;             2 if the name could be resolved locally
2904   4FEA             ;         L.H.E.D = Resolved IP address
2905   4FEA             ;                   (only if no error occurred and B=1 or 2 is returned)
2906   4FEA             ;RAM Buffer to store names to be resolved (and used also to translate IPs from ASCII to 32bits number)
2907   4FEA             ;Will store the result of the last DNS query
2908   4FEA             TCPIP_DNS_Q:
2909   4FEA E5              push    hl                      ; Save HL
2910   4FEB AF              xor a
2911   4FEC 5F              ld  e,a
2912   4FED 57              ld  d,a                         ; Zero DE
2913   4FEE             TCPIP_DNS_Q_SIZE_LOOP:
2914   4FEE 7E              ld  a,(hl)                      ; so let's check the size of dns data
2915   4FEF B7              or  a                           ; it is zero terminated
2916   4FF0 28 05           jr  z,TCPIP_DNS_Q_SEND          ; if zero, end of string
2917   4FF2 13              inc de                          ; ok, not zero, one more char
2918   4FF3 23              inc hl                          ; next
2919   4FF4 C3 EE 4F        jp  TCPIP_DNS_Q_SIZE_LOOP       ; jp is a tad bit faster and we are not worried about code size
2920   4FF7             TCPIP_DNS_Q_SEND:
2921   4FF7                 ; Here we send the query and wait the result
2922   4FF7 13              inc de                          ; add 1, we will send flag first
2923   4FF8 3E CE           ld  a,206                       ; DNS_Q_NEW
2924   4FFA                 SEND_DATA                       ; Send the command
2924   4FFA 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2925   4FFD 7A              ld  a,d
2926   4FFE                 SEND_DATA                       ; Send the command size msb
2926   4FFE 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2927   5001 7B              ld  a,e
2928   5002                 SEND_DATA                       ; Send the command size lsb
2928   5002 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2929   5005 78              ld  a,b
2930   5006                 SEND_DATA                       ; Send the flag byte
2930   5006 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2931   5009             
2932   5009                 if USE_MEM_IO = 0
2933   5009~                ; now otir of DNS/DNS BUFFER DATA SIZE
2934   5009~                ld  c,OUT_TX_PORT               ; our data TX port
2935   5009                 endif
2936   5009 E1              pop hl                          ; string to try to resolve
2937   500A 1B              dec de                          ; we are sending just data addressed by HL, so revert count
2938   500B 7A              ld  a,d
2939   500C B3              or  e                           ; if de zero, no string, wrong parameters, but let the ESP answer
2940   500D CA 1F 50        jp  z,TCPIP_DNS_Q_WAIT_RSP
2941   5010 AF              xor a
2942   5011                 ; Fast 16 bit variable size loop by GRAUW
2943   5011 43              ld  b,e
2944   5012 1B              dec de
2945   5013 14              inc d
2946   5014             TCPIP_DNS_Q_SENDLP:
2947   5014                 ; send it
2948   5014                 if USE_MEM_IO = 0
2949   5014~                outi
2950   5014~                jp  nz,TCPIP_DNS_Q_SENDLP
2951   5014                 else
2952   5014 7E              ld  a,(hl)
2953   5015 32 07 7F        ld  (MEM_OUT_TX_PORT),a
2954   5018 23              inc hl
2955   5019 10 F9           djnz TCPIP_DNS_Q_SENDLP
2956   501B                 endif
2957   501B 15              dec d
2958   501C C2 14 50        jp  nz,TCPIP_DNS_Q_SENDLP
2959   501F             TCPIP_DNS_Q_WAIT_RSP:
2960   501F                 ; Now wait up to 900 ticks (15s@60Hz) to get response
2961   501F 21 84 03        ld  hl,900
2962   5022 CD 07 5A        call    SETCOUNTER
2963   5025             TCPIP_DNSQ_SEND_ST1:
2964   5025                 CHECK_DATA
2964   5025 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2964   5028 CB 47       >    bit 0,a                         ; If nz has data
2965   502A 20 05           jr  nz,TCPIP_DNSQ_SEND_ST1.1
2966   502C CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2967   502F 18 F4           jr  TCPIP_DNSQ_SEND_ST1
2968   5031             TCPIP_DNSQ_SEND_ST1.1:
2969   5031                 ; nz, check the data
2970   5031                 RECEIVE_DATA
2970   5031 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2971   5034 FE CE           cp  206                         ; Is response of our command?
2972   5036 20 ED           jr  nz,TCPIP_DNSQ_SEND_ST1
2973   5038                 ; now get return code, if return code other than 0, it is finished
2974   5038             TCPIP_DNSQ_SEND_RC:
2975   5038                 CHECK_DATA
2975   5038 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2975   503B CB 47       >    bit 0,a                         ; If nz has data
2976   503D 20 05           jr  nz,TCPIP_DNSQ_SEND_RC.1
2977   503F CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2978   5042 18 F4           jr  TCPIP_DNSQ_SEND_RC
2979   5044             TCPIP_DNSQ_SEND_RC.1:
2980   5044                 ; nz, discard
2981   5044                 RECEIVE_DATA
2981   5044 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2982   5047 B7              or  a                           ; 0?
