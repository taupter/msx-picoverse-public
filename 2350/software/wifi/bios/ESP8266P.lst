3045   50AB             ;===  TCPIP_DNS_S  ===
3046   50AB             ;=====================
3047   50AB             ;Obtains the host name resolution process state and result.
3048   50AB             ;
3049   50AB             ;Input:  A = 7
3050   50AB             ;        B = Flags, when set to 1 they instruct the resolver to:
3051   50AB             ;            bit 0: Clear any existing result or error condition after the execution
3052   50AB             ;                   (except if there is a query in progress)
3053   50AB             ;Output: A = Error code
3054   50AB             ;        B = DNS error code (when error is ERR_DNS)
3055   50AB             ;        B = Current query status (when error is ERR_OK):
3056   50AB             ;            0: There is no query in progress, nor any result nor error code available
3057   50AB             ;            1: There is a query in progress
3058   50AB             ;            2: Query is complete
3059   50AB             ;        C = Current query sub status (when error is ERR_OK and B=1):
3060   50AB             ;            0: Unknown
3061   50AB             ;            1: Querying the primary DNS server
3062   50AB             ;            2: Querying the secondary DNS server
3063   50AB             ;            3: Querying another DNS server
3064   50AB             ;        C = Resolution process type (when error is ERR_OK and B=2):
3065   50AB             ;            0: The name was obtained by querying a DNS server
3066   50AB             ;            1: The name was a direct representation of an IP address
3067   50AB             ;            2: The name was resolved locally
3068   50AB             ;       L.H.E.D = Resolved IP address (when error is ERR_OK and B=2)
3069   50AB             TCPIP_DNS_S:
3070   50AB                 ;--- Is there a result?
3071   50AB CD EC 5A        call    GETDNSREADY             ; DNS done?
3072   50AE B7              or  a
3073   50AF 28 23           jr  z,TCPIP_DNS_S_NORESULT      ; No DNS result
3074   50B1                 ;--- Ok, we have a result, is it success?
3075   50B1 3D              dec a
3076   50B2 28 12           jr  z,TCPIP_DNS_S_HASRESULT     ; If it is 1, it was not an error
3077   50B4                 ;--- Shoot, there is an error...
3078   50B4                 ;--- And sure thing, ESP do not tell us details, it is always failure :-P
3079   50B4 CB 40           bit 0,b                         ;--- clear error after this?
3080   50B6 28 09           jr  z,TCP_IP_DNS_S_NOCLR
3081   50B8                 ;--- Clear
3082   50B8 06 00           ld b,0                          ;--- Like I've said, no details
3083   50BA AF              xor a
3084   50BB CD FE 5A        call    SETDNSREADY             ; DNS not done
3085   50BE 3E 08           ld  a,ERR_DNS;
3086   50C0 C9              ret
3087   50C1             TCP_IP_DNS_S_NOCLR:
3088   50C1                 ;--- Don't clear
3089   50C1 3E 08           ld  a,ERR_DNS
3090   50C3 06 00           ld  b,0                         ;--- Like I've said, no details
3091   50C5 C9              ret
3092   50C6                 ;--- There is a result available...
3093   50C6             TCPIP_DNS_S_HASRESULT:
3094   50C6                 ;--- Copy the result
3095   50C6 CD 12 5B        call    GETDNSRESULT
3096   50C9 AF              xor a
3097   50CA CB 40           bit 0,b                         ;--- clear result after this?
3098   50CC 28 03           jr  z,TCP_IP_DNS_S_RES_NOCLR    ;--- no, just return
3099   50CE                 ;--- Yes, clear
3100   50CE CD FE 5A        call    SETDNSREADY             ; DNS not done
3101   50D1             TCP_IP_DNS_S_RES_NOCLR:
3102   50D1 06 02           ld  b,2
3103   50D3 C9              ret
3104   50D4             
