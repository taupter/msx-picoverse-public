1809   4A7D 3E 3A           ld  a,':'
1810   4A7F DD 23           inc ix
1811   4A81 DD 23           inc ix                          ; Nagle response is two or three bytes long, let's check
1812   4A83 0B              dec bc
1813   4A84 0B              dec bc                          ; Remaining bytes
1814   4A85 DD BE 00        cp  (ix+0)
1815   4A88 CA 94 4A        jp  z,CHECKTIMEOUT.1
1816   4A8B DD 23           inc ix
1817   4A8D 0B              dec bc                          ; Remaining bytes
1818   4A8E DD BE 00        cp  (ix+0)
1819   4A91 C2 09 4B        jp  nz,MENU_SUB_BAD_END         ; If not here, sorry to say it is an error
1820   4A94             CHECKTIMEOUT.1:
1821   4A94 78              ld  a,b
1822   4A95 B1              or  c                           ; All data read?
1823   4A96 CA 09 4B        jp  z,MENU_SUB_BAD_END          ; If so, sorry to say it is an error
1824   4A99 DD 23           inc ix                          ; At the first digit
1825   4A9B 0B              dec bc                          ; Remaining bytes
1826   4A9C 78              ld  a,b
1827   4A9D B1              or  c                           ; All data read?
1828   4A9E CA 09 4B        jp  z,MENU_SUB_BAD_END          ; If so, sorry to say it is an error
1829   4AA1 DD E5           push    ix                      ; This is the start of the string, save it
1830   4AA3 26 00           ld  h,0                         ; No digit so far
1831   4AA5                 ; It can have up to three digits
1832   4AA5             CHECKTIMEOUT.2:
1833   4AA5 3E 3A           ld  a,':'
1834   4AA7 DD BE 00        cp  (ix+0)                      ; Check if it is the separator
1835   4AAA CA CB 4A        jp  z,CHECKTIMEOUT.3            ; If it is routine will follow through
1836   4AAD DD 7E 00        ld  a,(ix+0)                    ; Get the supposed digit in A
1837   4AB0 2E 3A           ld  l,'9'+1
1838   4AB2 BD              cp  l
1839   4AB3 D2 08 4B        jp  nc,MENU_SUB_BAD_END_1S      ; If more than '9', sorry to say it is an error
1840   4AB6 2E 30           ld  l,'0'
1841   4AB8 BD              cp  l
1842   4AB9 DA 08 4B        jp  c,MENU_SUB_BAD_END_1S       ; If less than '0', sorry to say it is an error
1843   4ABC 24              inc h                           ; It is not, so it is a digit
1844   4ABD 3E 03           ld  a,3
1845   4ABF BC              cp  h
1846   4AC0 DA 08 4B        jp  c,MENU_SUB_BAD_END_1S       ; If more than three digits, sorry to say it is an error
1847   4AC3 DD 23           inc ix                          ; Increase pointer
1848   4AC5 0B              dec bc                          ; Decrease remaining
1849   4AC6 78              ld  a,b
1850   4AC7 B1              or  c                           ; All data read?
1851   4AC8 C2 A5 4A        jp  nz,CHECKTIMEOUT.2           ; Not, so rinse and repeat
1852   4ACB             CHECKTIMEOUT.3:
1853   4ACB DD 36 00 00     ld  (ix+0),0                    ; Null terminate string value
1854   4ACF DD 2B           dec ix
1855   4AD1 DD 7E 00        ld  a,(ix+0)                    ; 1st Digit in A
1856   4AD4 D6 30           sub '0'                         ; Convert it to decimal value
1857   4AD6 5F              ld  e,a
1858   4AD7 16 00           ld  d,0                         ; DE has first digit
1859   4AD9 25              dec h                           ; Decrement digit counter
1860   4ADA 28 28           jr  z,CHECKTIMEOUT.END          ; If all digits, done
1861   4ADC                 ; Now second digit, multiply it by 10 and add to E, even if 90 + 9, still fits E
1862   4ADC DD 2B           dec ix
1863   4ADE DD 7E 00        ld  a,(ix+0)                    ; 2nd Digit
1864   4AE1 D6 30           sub '0'                         ; Convert it to decimal value
1865   4AE3 87              add a,a                         ; A has *2
1866   4AE4 4F              ld  c,a                         ; C has *2
1867   4AE5 87              add a,a                         ; A has *4
1868   4AE6 87              add a,a                         ; A has *8
1869   4AE7 81              add a,c                         ; A has *10
1870   4AE8 83              add a,e                         ; A has two digits result
1871   4AE9 5F              ld  e,a                         ; Back to E, DE has two digits results
1872   4AEA 25              dec h                           ; Decrement digit counter
1873   4AEB 28 17           jr  z,CHECKTIMEOUT.END          ; If all digits, done
