2295   4D18             
2296   4D18                 ; A>1: A=A-1, and jump to old hook
2297   4D18             
2298   4D18             DO_EXTBIO3:                         ; A=A-1 already done
2299   4D18 E3              ex  (sp),hl
2300   4D19 11 22 22        ld  de,#2222
2301   4D1C C9              ret
2302   4D1D             
2303   4D1D             
2304   4D1D             ; Jump here to execute old EXTBIO code
2305   4D1D             JUMP_OLD2:
2306   4D1D 11 22 22        ld  de,#2222
2307   4D20             JUMP_OLD:                           ; Assumes "push hl,bc,af" done
2308   4D20 D5              push    de
2309   4D21 CD 67 59        call    GETSLT
2310   4D24 CD C0 59        call    GETWRK
2311   4D27 D1              pop de
2312   4D28 F1              pop af
2313   4D29 C1              pop bc
2314   4D2A E3              ex  (sp),hl
2315   4D2B C9              ret
2316   4D2C             
2317   4D2C             ;====================================
2318   4D2C             ;===  Functions entry point code  ===
2319   4D2C             ;====================================
2320   4D2C             UNAPI_ENTRY:
2321   4D2C FB              ei
2322   4D2D E5              push    hl
2323   4D2E F5              push    af
2324   4D2F 21 4D 4D        ld  hl,FN_TABLE
2325   4D32 CB 7F           bit 7,a
2326   4D34             
2327   4D34                 if  MAX_IMPFN >= 128
2328   4D34~            
2329   4D34~                jr  z,IS_STANDARD
2330   4D34~                ld  hl,IMPFN_TABLE
2331   4D34~                and %01111111
2332   4D34~                cp  MAX_IMPFN-128
2333   4D34~                jr  z,OK_FNUM
2334   4D34~                jr  nc,UNDEFINED
2335   4D34~            IS_STANDARD:
2336   4D34~            
2337   4D34                 else
2338   4D34             
2339   4D34 20 14           jr  nz,UNDEFINED
2340   4D36             
2341   4D36                 endif
2342   4D36             
2343   4D36 FE 1D           cp  MAX_FN
2344   4D38 28 02           jr  z,OK_FNUM
2345   4D3A 30 0E           jr  nc,UNDEFINED
2346   4D3C             
2347   4D3C             OK_FNUM:
2348   4D3C 87              add a,a
2349   4D3D D5              push    de
2350   4D3E 5F              ld  e,a
2351   4D3F 16 00           ld  d,0
2352   4D41 19              add hl,de
2353   4D42 D1              pop de
2354   4D43             
2355   4D43 7E              ld  a,(hl)
2356   4D44 23              inc hl
2357   4D45 66              ld  h,(hl)
2358   4D46 6F              ld  l,a
2359   4D47             
2360   4D47 F1              pop af
2361   4D48 E3              ex  (sp),hl
2362   4D49 C9              ret
2363   4D4A             
2364   4D4A             ; Undefined function: return with registers unmodified
2365   4D4A             UNDEFINED:
2366   4D4A F1              pop af
2367   4D4B E1              pop hl
2368   4D4C C9              ret
2369   4D4D             
2370   4D4D             ;===================================
2371   4D4D             ;===  Functions addresses table  ===
2372   4D4D             ;===================================
2373   4D4D             ;--- Implementation-specific routines addresses table
2374   4D4D             
2375   4D4D                 if  MAX_IMPFN >= 128
2376   4D4D~            
2377   4D4D~            IMPFN_TABLE:
2378   4D4D~            FN_128:                 dw  FN_DUMMY
2379   4D4D~            
2380   4D4D                 endif
2381   4D4D             
2382   4D4D             FN_TABLE:
2383   4D4D 9E 4D       FN_0:                   dw  UNAPI_GET_INFO
2384   4D4F A9 4D       FN_1:                   dw  TCPIP_GET_CAPAB
2385   4D51 01 4F       FN_2:                   dw  TCPIP_GET_IPINFO
2386   4D53 90 4F       FN_3:                   dw  TCPIP_NET_STATE
2387   4D55             ; TCPIP_SEND_ECHO not going to be implemented, ESP do not support ping like UNAPI specify
2388   4D55 89 4D       FN_4:                   dw  FN_NOT_IMP
2389   4D57             ; TCPIP_RCV_ECHO not going to be implemented as SEND_ECHO is not implemented
2390   4D57 89 4D       FN_5:                   dw  FN_NOT_IMP
2391   4D59 EA 4F       FN_6:                   dw  TCPIP_DNS_Q
2392   4D5B AB 50       FN_7:                   dw  TCPIP_DNS_S
2393   4D5D D8 50       FN_8:                   dw  TCPIP_UDP_OPEN
2394   4D5F 40 51       FN_9:                   dw  TCPIP_UDP_CLOSE
2395   4D61 90 51       FN_10:                  dw  TCPIP_UDP_STATE
2396   4D63 2F 52       FN_11:                  dw  TCPIP_UDP_SEND
2397   4D65 E2 52       FN_12:                  dw  TCPIP_UDP_RCV
2398   4D67 33 54       FN_13:                  dw  TCPIP_TCP_OPEN
2399   4D69 08 55       FN_14:                  dw  TCPIP_TCP_CLOSE
2400   4D6B 58 55       FN_15:                  dw  TCPIP_TCP_ABORT
2401   4D6D CD 55       FN_16:                  dw  TCPIP_TCP_STATE
2402   4D6F 07 57       FN_17:                  dw  TCPIP_TCP_SEND
2403   4D71 AE 57       FN_18:                  dw  TCPIP_TCP_RCV
2404   4D73             ; TCPIP_TCP_FLUSH makes no sense as we do not use buffers to send, any buffer is internal to ESP and we can't delete
2405   4D73 89 4D       FN_19:                  dw  FN_NOT_IMP
2406   4D75             ; TCPIP_RAW_OPEN not going to be implemented, ESP do not support RAW connections
2407   4D75 89 4D       FN_20:                  dw  FN_NOT_IMP
2408   4D77             ; TCPIP_RAW_CLOSE not going to be implemented, ESP do not support RAW connections
2409   4D77 89 4D       FN_21:                  dw  FN_NOT_IMP
2410   4D79             ; TCPIP_RAW_STATE not going to be implemented, ESP do not support RAW connections
2411   4D79 89 4D       FN_22:                  dw  FN_NOT_IMP
2412   4D7B             ; TCPIP_RAW_SEND not going to be implemented, ESP do not support RAW connections
2413   4D7B 89 4D       FN_23:                  dw  FN_NOT_IMP
2414   4D7D             ; TCPIP_RAW_RCV not going to be implemented, ESP do not support RAW connections
2415   4D7D 89 4D       FN_24:                  dw  FN_NOT_IMP
2416   4D7F 98 58       FN_25:                  dw  TCPIP_CONFIG_AUTOIP
2417   4D81 FC 58       FN_26:                  dw  TCPIP_CONFIG_IP
2418   4D83 45 59       FN_27:                  dw  TCPIP_CONFIG_TTL
2419   4D85 57 59       FN_28:                  dw  TCPIP_CONFIG_PING
2420   4D87             ; TCPIP_WAIT not needed for our implementation
2421   4D87 8C 4D       FN_29:                  dw  END_OK
2422   4D89             
2423   4D89             ;========================
2424   4D89             ;===  Functions code  ===
2425   4D89             ;========================
2426   4D89             FN_NOT_IMP:
2427   4D89 3E 01           ld  a,ERR_NOT_IMP
2428   4D8B C9              ret
2429   4D8C             
2430   4D8C             END_OK:
2431   4D8C AF              xor a
2432   4D8D C9              ret
2433   4D8E             
2434   4D8E             ; Most functions do not have special handling on time out and can use this.
2435   4D8E             ; If there is a need to retry sending or receiving on time-out, then a custom
2436   4D8E             ; time-out function must be done, check the examples of UDP and TCP receive
2437   4D8E             TCPIP_GENERIC_CHECK_TIME_OUT:
2438   4D8E                 ; Save registers other than AF
2439   4D8E C5              push bc
2440   4D8F D5              push de
2441   4D90 E5              push hl
2442   4D91 CD F8 59        call    GETCOUNTER
2443   4D94 7D              ld  a,l
2444   4D95 B4              or  h
2445   4D96                 ; Restore registers, we are returning
2446   4D96 E1              pop hl
2447   4D97 D1              pop de
2448   4D98 C1              pop bc
2449   4D99 C0              ret nz
2450   4D9A                 ; Ok, timeout...
2451   4D9A F1              pop af                          ; Get return address of who called this out of the stack
2452   4D9B 3E 0F           ld  a,ERR_INV_OPER
2453   4D9D C9              ret                             ; and return the function itself
2454   4D9E             
2455   4D9E             ;========================
2456   4D9E             ;===  UNAPI_GET_INFO  ===
2457   4D9E             ;========================
2458   4D9E             ; Obtain the implementation name and version.
2459   4D9E             ;
2460   4D9E             ;    Input:  A  = 0
2461   4D9E             ;    Output: HL = Descriptive string for this implementation, on this slot, zero terminated
2462   4D9E             ;            DE = API version supported, D.E
2463   4D9E             ;            BC = This implementation version, B.C.
2464   4D9E             ;            A  = 0 and Cy = 0
2465   4D9E             UNAPI_GET_INFO:
2466   4D9E 01 03 01        ld  bc,256*ROM_V_P+ROM_V_S
2467   4DA1 11 02 01        ld  de,256*API_V_P+API_V_S
2468   4DA4 21 27 6A        ld  hl,APIINFO
2469   4DA7 AF              xor a
2470   4DA8 C9              ret
2471   4DA9             
2472   4DA9             ;=========================
2473   4DA9             ;===  TCPIP_GET_CAPAB  ===
2474   4DA9             ;=========================
2475   4DA9             ; Get information about the TCP/IP capabilities and features.
2476   4DA9             ;
2477   4DA9             ;    Input:  A = 1
2478   4DA9             ;            B = Index of information block to retrieve:
2479   4DA9             ;                1: Capabilities and features flags, link level protocol
2480   4DA9             ;                2: Connection pool size and status
2481   4DA9             ;                3: Maximum datagram size allowed
2482   4DA9             ;                4: Second set of capabilities and features flags
2483   4DA9             ;    Output: A = Error code
2484   4DA9             ;        When information block 1 requested:
2485   4DA9             ;            HL = Capabilities flags
2486   4DA9             ;            DE = Features flags
2487   4DA9             ;            B  = Link level protocol used
2488   4DA9             ;        When information block 2 requested:
2489   4DA9             ;            B = Maximum simultaneous TCP connections supported
2490   4DA9             ;            C = Maximum simultaneous UDP connections supported
2491   4DA9             ;            D = Free TCP connections currently available
2492   4DA9             ;            E = Free UDP connections currently available
2493   4DA9             ;            H = Maximum simultaneous raw IP connections supported
2494   4DA9             ;            L = Free raw IP connections currently available
2495   4DA9             ;        When information block 3 requested:
2496   4DA9             ;            HL = Maximum incoming datagram size supported
2497   4DA9             ;            DE = Maximum outgoing datagram size supported
2498   4DA9             ;        When information block 4 requested:
2499   4DA9             ;            HL = Second set of capabilities flags
2500   4DA9             ;            DE = Second set of features flags (currently unused, always zero)
2501   4DA9             TCPIP_GET_CAPAB:
2502   4DA9                 SEND_DATA                       ; Send the command
2502   4DA9 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2503   4DAC AF              xor a
2504   4DAD                 SEND_DATA                       ; Send the command size msb
2504   4DAD 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2505   4DB0 3C              inc a
2506   4DB1                 SEND_DATA                       ; Send the command size lsb
2506   4DB1 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2507   4DB4 78              ld  a,b
2508   4DB5 CD 29 5A        call    SETBYTE                 ; Save it, we are going to need it later
2509   4DB8                 SEND_DATA                       ; Send the parameter
2509   4DB8 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2510   4DBB             
2511   4DBB                 ; Now wait up to 120 ticks to get response
2512   4DBB 21 78 00        ld  hl,120
2513   4DBE CD 07 5A        call    SETCOUNTER
2514   4DC1             TCPIP_GET_CAPAB_ST1:
2515   4DC1                 CHECK_DATA
2515   4DC1 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2515   4DC4 CB 47       >    bit 0,a                         ; If nz has data
2516   4DC6 20 05           jr  nz,TCPIP_GET_CAPAB_ST1.1
2517   4DC8 CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2518   4DCB 18 F4           jr  TCPIP_GET_CAPAB_ST1
2519   4DCD             TCPIP_GET_CAPAB_ST1.1:
2520   4DCD                 ; nz, check the data
2521   4DCD                 RECEIVE_DATA
2521   4DCD 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2522   4DD0 FE 01           cp  1                           ; Is response of our command?
2523   4DD2 20 ED           jr  nz,TCPIP_GET_CAPAB_ST1
2524   4DD4                 ; Now get return code, if return code other than 0, it is finished
2525   4DD4             TCPIP_GET_CAPAB_RC:
2526   4DD4                 CHECK_DATA
2526   4DD4 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2526   4DD7 CB 47       >    bit 0,a                         ; If nz has data
2527   4DD9 20 05           jr  nz,TCPIP_GET_CAPAB_RC.1
2528   4DDB CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2529   4DDE 18 F4           jr  TCPIP_GET_CAPAB_RC
2530   4DE0             TCPIP_GET_CAPAB_RC.1:
2531   4DE0                 ; nz, discard
2532   4DE0                 RECEIVE_DATA
2532   4DE0 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2533   4DE3 B7              or  a                           ; 0?
2534   4DE4 C0              ret nz                          ; If not, done
2535   4DE5             
2536   4DE5                 ; Next two bytes are return code and size bytes, don't care
2537   4DE5 06 02           ld  b,2
2538   4DE7             TCPIP_GET_CAPAB_ST2:
2539   4DE7                 CHECK_DATA
2539   4DE7 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2539   4DEA CB 47       >    bit 0,a                         ; If nz has data
2540   4DEC 20 05           jr  nz,TCPIP_GET_CAPAB_ST2.1
2541   4DEE CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2542   4DF1 18 F4           jr  TCPIP_GET_CAPAB_ST2
2543   4DF3             TCPIP_GET_CAPAB_ST2.1:
2544   4DF3                 ; Nz, discard
2545   4DF3                 RECEIVE_DATA
2545   4DF3 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2546   4DF6 05              dec b
2547   4DF7 20 EE           jr  nz,TCPIP_GET_CAPAB_ST2
2548   4DF9             
2549   4DF9                 ; Now check if block 1, 2 or 3
2550   4DF9 CD 17 5A        call    GETBYTE                 ; Get the parameter we saved at the start
2551   4DFC 3D              dec a
2552   4DFD CA AF 4E        jp  z,TCPIP_GET_CAPAB_BLK1      ; 1
2553   4E00 3D              dec a
2554   4E01 CA 4D 4E        jp  z,TCPIP_GET_CAPAB_BLK2      ; 2
2555   4E04 3D              dec a
2556   4E05 CA 0B 4E        jp  z,TCPIP_GET_CAPAB_BLK3      ; 3
2557   4E08                 ; Else, only block four, same as block 1
2558   4E08 C3 AF 4E        jp  TCPIP_GET_CAPAB_BLK1        ; 1
2559   4E0B                 ; Block 3 Handling, we will receive L, H, E and D
2560   4E0B             TCPIP_GET_CAPAB_BLK3:
2561   4E0B             TCPIP_GET_CAPAB_BLK3_ST1:
2562   4E0B                 CHECK_DATA
2562   4E0B 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2562   4E0E CB 47       >    bit 0,a                         ; If nz has data
2563   4E10 20 05           jr  nz,TCPIP_GET_CAPAB_BLK3_ST1.1
2564   4E12 CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2565   4E15 18 F4           jr  TCPIP_GET_CAPAB_BLK3_ST1
2566   4E17             TCPIP_GET_CAPAB_BLK3_ST1.1:
2567   4E17                 ; nz, get it
2568   4E17                 RECEIVE_DATA
2568   4E17 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2569   4E1A 6F              ld  l,a
2570   4E1B             TCPIP_GET_CAPAB_BLK3_ST2:
2571   4E1B                 CHECK_DATA
2571   4E1B 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2571   4E1E CB 47       >    bit 0,a                         ; If nz has data
2572   4E20 20 05           jr  nz,TCPIP_GET_CAPAB_BLK3_ST2.1
2573   4E22 CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2574   4E25 18 F4           jr  TCPIP_GET_CAPAB_BLK3_ST2
2575   4E27             TCPIP_GET_CAPAB_BLK3_ST2.1:
2576   4E27                 ; nz, get it
2577   4E27                 RECEIVE_DATA
2577   4E27 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2578   4E2A 67              ld  h,a
2579   4E2B             TCPIP_GET_CAPAB_BLK3_ST3:
2580   4E2B                 CHECK_DATA
2580   4E2B 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2580   4E2E CB 47       >    bit 0,a                         ; If nz has data
2581   4E30 20 05           jr  nz,TCPIP_GET_CAPAB_BLK3_ST3.1
2582   4E32 CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2583   4E35 18 F4           jr  TCPIP_GET_CAPAB_BLK3_ST3
2584   4E37             TCPIP_GET_CAPAB_BLK3_ST3.1:
2585   4E37                 ; nz, get it
2586   4E37                 RECEIVE_DATA
2586   4E37 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2587   4E3A 5F              ld  e,a
2588   4E3B             TCPIP_GET_CAPAB_BLK3_ST4:
2589   4E3B                 CHECK_DATA
2589   4E3B 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2589   4E3E CB 47       >    bit 0,a                         ; If nz has data
2590   4E40 20 05           jr  nz,TCPIP_GET_CAPAB_BLK3_ST4.1
2591   4E42 CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2592   4E45 18 F4           jr  TCPIP_GET_CAPAB_BLK3_ST4
2593   4E47             TCPIP_GET_CAPAB_BLK3_ST4.1:
2594   4E47                 ; nz, get it
2595   4E47                 RECEIVE_DATA
2595   4E47 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2596   4E4A 57              ld  d,a
2597   4E4B                 ; Done
2598   4E4B AF              xor a
2599   4E4C C9              ret
2600   4E4D             
2601   4E4D             TCPIP_GET_CAPAB_BLK2:
2602   4E4D                 ; Block 2 Handling, we will receive B, C, D, E, H, L
2603   4E4D             TCPIP_GET_CAPAB_BLK2_ST1:
2604   4E4D                 CHECK_DATA
2604   4E4D 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
