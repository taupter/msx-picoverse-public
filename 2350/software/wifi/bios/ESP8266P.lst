2821   4F90             ;Output: A = Error code
2822   4F90             ;        B = Current network state:
2823   4F90             ;            0: Closed
2824   4F90             ;            1: Opening
2825   4F90             ;            2: Open
2826   4F90             ;            3: Closing
2827   4F90             ;            255: Unknown
2828   4F90             TCPIP_NET_STATE:
2829   4F90                 SEND_DATA                       ; Send the command
2829   4F90 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2830   4F93 AF              xor a
2831   4F94                 SEND_DATA                       ; Send the command size msb
2831   4F94 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2832   4F97                 SEND_DATA                       ; Send the command size lsb
2832   4F97 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
2833   4F9A             
2834   4F9A                 ; Now wait up to 720 ticks to get response
2835   4F9A 21 D0 02        ld  hl,720
2836   4F9D CD 07 5A        call    SETCOUNTER
2837   4FA0             TCPIP_NET_STATE_ST1:
2838   4FA0                 CHECK_DATA
