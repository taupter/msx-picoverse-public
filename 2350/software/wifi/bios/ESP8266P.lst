4728   590D                 SEND_DATA                       ; Send the IP first byte
4728   590D 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4729   5910 7C              ld  a,h
4730   5911                 SEND_DATA                       ; Send the IP second byte
4730   5911 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4731   5914 7B              ld  a,e
4732   5915                 SEND_DATA                       ; Send the IP third byte
4732   5915 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4733   5918 7A              ld  a,d
4734   5919                 SEND_DATA                       ; Send the IP fourth byte
4734   5919 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4735   591C             
4736   591C                 ; Now wait up to 180 ticks to get response
4737   591C 21 B4 00        ld  hl,180
4738   591F CD 07 5A        call    SETCOUNTER
4739   5922             TCPIP_CONFIG_IP_ST1:
4740   5922                 CHECK_DATA
4740   5922 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
4740   5925 CB 47       >    bit 0,a                         ; If nz has data
4741   5927 20 05           jr  nz,TCPIP_CONFIG_IP_ST1.1
4742   5929 CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
4743   592C 18 F4           jr  TCPIP_CONFIG_IP_ST1
4744   592E             TCPIP_CONFIG_IP_ST1.1:
4745   592E                 ; nz, check the data
4746   592E                 RECEIVE_DATA
4746   592E 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
4747   5931 FE 1A           cp  26                          ; Is response of our command?
4748   5933 20 ED           jr  nz,TCPIP_CONFIG_IP_ST1
4749   5935                 ; now get return code, and that is it
4750   5935             TCPIP_CONFIG_IP_RC:
4751   5935                 CHECK_DATA
4751   5935 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
4751   5938 CB 47       >    bit 0,a                         ; If nz has data
