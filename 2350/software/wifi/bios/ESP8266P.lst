0453   40B8 CD 80 4C        call    PRINTHL
0454   40BB             BOOT_FROM_POWER_OFF.2:
0455   40BB                 endif
0456   40BB 3E 06           ld  a,6
0457   40BD CD 41 01        call    SNSMAT
0458   40C0 CB 77           bit 6,a                         ; Test [F2]
0459   40C2 C2 E9 40        jp  nz,INIT_UNAPI               ; If F2 is not pressed, let's proceed to INIT_UNAPI
0460   40C5                 ; F2 is pressed, continue
0461   40C5             F2_IS_PRESSED:
0462   40C5 CD 98 5B        call    RESET_ESP
0463   40C8 B7              or  a
0464   40C9 20 06           jr  nz,ESP_NOT_FOUND
0465   40CB 21 3D 69        ld  hl,OK_S                     ; Properly detected
0466   40CE C3 DB 40        jp  INIT_F_MSG                  ; Well, if reset successful, continue
0467   40D1             ESP_NOT_FOUND:
0468   40D1                 ; If here, ESP was not found, so, exit with an error message
0469   40D1 78              ld  a,b
0470   40D2 B7              or  a
0471   40D3 21 58 69        ld  hl,FAIL_S                   ; If 0, non responsive
0472   40D6 28 03           jr  z,INIT_F_MSG
0473   40D8 21 A6 69        ld  hl,FAIL_F                   ; Otherwise, firmware is old
0474   40DB             INIT_F_MSG:
0475   40DB CD 80 4C        call    PRINTHL
0476   40DE             INIT_F_WAIT:
0477   40DE 06 B4           ld  b,180                       ; 3s
0478   40E0             INIT_F_LOOP_WAIT:
0479   40E0 76              halt
0480   40E1 10 FD           djnz    INIT_F_LOOP_WAIT
0481   40E3             AND_DONE:
0482   40E3 3E EF           ld  a,#EF                       ; Set #EF, ESP Not Found
0483   40E5                 WRITE_F2                        ; on port #F2
0483   40E5 32 05 7F    >    ld  (MEM_PORT_F2),a
0484   40E8 C9              ret                             ; And done
0485   40E9             INIT_UNAPI:
0486   40E9                 CLEAR_UART
0486   40E9 3E 14       >    ld  a,20
0486   40EB 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0487   40EE 3E 63           ld  a,CMD_QUERY_ACLK_SETTINGS
0488   40F0                 SEND_DATA
0488   40F0 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0489   40F3 21 3C 00        ld  hl,60                       ; Wait Up To 1s
0490   40F6 ED 5B 76 F6     ld  de,(TXTTAB)                 ; We will borrow Basic Program memory area for now...
0491   40FA DD 6B           ld  ixl,e
0492   40FC DD 62           ld  ixh,d                       ; Address in IX
0493   40FE CD 58 4B        call    WAIT_MENU_CMD_RESPONSE
0494   4101 CA 98 41        jp  z,INIT_NOCLOCKUPDATE        ; If error, just skip
0495   4104                 ; Response received, IX+0 and IX+1 has Auto Clock and GMT
0496   4104 3E 03           ld  a,3
0497   4106 DD BE 00        cp  (ix+0)
0498   4109 20 0B           jr  nz,INIT_UNAPI2              ; If not disabled continue on INIT_UNAPI2
0499   410B                 ; Disabled, ok, so let's ensure connection is not locked (just in case it was setup as disabled right now)
0500   410B                 CLEAR_UART
0500   410B 3E 14       >    ld  a,20
0500   410D 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0501   4110 3E 68           ld  a,CMD_WIFIRELEASE_ESP
0502   4112                 SEND_DATA                       ; Just send, no need to wait response
0502   4112 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0503   4115 C9              ret
0504   4116             INIT_UNAPI2:
0505   4116 3A 2D 00        ld  a,(#002D)                   ; Check MSX Version
0506   4119 B7              or  a
0507   411A 28 7C           jr  z,INIT_NOCLOCKUPDATE        ; If zero, MSX1, can't set clock
0508   411C AF              xor a
0509   411D DD B6 00        or  (ix+0)
0510   4120 28 76           jr  z,INIT_NOCLOCKUPDATE        ; if turned off, skip
0511   4122                 ; Ok, not zero, so we are going to simply request the time, it might take up to 10s
0512   4122 DD 23           inc ix
0513   4124 DD 23           inc ix                          ; ok, leave IX+0 and IX+1 intact
0514   4126                 ; b = number of response check attempts
0515   4126 06 05           ld  b,5                         ; 5 * 2s = 10s
0516   4128                 CLEAR_UART
0516   4128 3E 14       >    ld  a,20
0516   412A 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0517   412D 3E 47           ld  a,CMD_GET_TIME
0518   412F                 SEND_DATA
0518   412F 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0519   4132             TRY_AGAIN:
0520   4132 C5              push    bc
0521   4133 21 78 00        ld  hl,120                      ; Wait Up To 2s per attempt
0522   4136 CD 58 4B        call    WAIT_MENU_CMD_RESPONSE
0523   4139 20 1E           jr  nz,INIT_CLOCKUPDATE         ; if ok, follow up
0524   413B 21 C5 69        ld  hl,STR_WAITING              ; Print Waiting for connection message
0525   413E CD 80 4C        call    PRINTHL
0526   4141 3E FF           ld  a,#ff
0527   4143 B8              cp  b                           ; Was time-out the failure reason?
0528   4144 C1              pop bc                          ; Restore stack ballance and retry counter
0529   4145 20 04           jr  nz,STOP_TRYING              ; If error return code and not time-out, no more checks needed
0530   4147 3E 47           ld  a,CMD_GET_TIME              ; Needed for retries
0531   4149 10 E7           djnz    TRY_AGAIN
0532   414B             STOP_TRYING:
0533   414B                 ; Leave a message that clock has not been updated
0534   414B 21 CF 68        ld  hl,STR_CLKUPDT_FAIL
0535   414E CD 80 4C        call    PRINTHL
0536   4151 3E F0           ld  a,240                       ; Wait 4 seconds with message on screen
0537   4153             WAIT_4S:
0538   4153 76              halt
0539   4154 3D              dec a
0540   4155                 ; If not zero, our time out has not elapsed
0541   4155 20 FC           jr  nz,WAIT_4S
0542   4157 18 3F           jr  INIT_NOCLOCKUPDATE          ; error, just skip to not set garbage in clock
0543   4159             INIT_CLOCKUPDATE:
0544   4159 C1              pop bc
0545   415A DD 2B           dec ix
0546   415C DD 2B           dec ix                          ; ix back where it should
0547   415E                 ; ix + 0 -> 0 If no need to set clock, 1 if set clock, 2 if set clock and request to turn Wi-Fi Off
0548   415E                 ; ix + 1 -> GMT setting, well, not going to use it
0549   415E                 ; ix + 2 -> Seconds
0550   415E                 ; ix + 3 -> Minutes
0551   415E                 ; ix + 4 -> Hours
0552   415E                 ; ix + 5 -> Day
0553   415E                 ; ix + 6 -> Month
0554   415E                 ; ix + 7 -> Year LSB
0555   415E                 ; ix + 8 -> Year MSB
0556   415E DD 66 04        ld  h,(ix+4)
0557   4161 DD 6E 03        ld  l,(ix+3)
0558   4164 DD 56 02        ld  d,(ix+2)
0559   4167 CD 43 5C        call    SET_TIME
0560   416A 20 2C           jr  nz,INIT_NOCLOCKUPDATE       ; if error, just skip
0561   416C DD 66 08        ld  h,(ix+8)
0562   416F DD 6E 07        ld  l,(ix+7)
0563   4172 DD 56 06        ld  d,(ix+6)
0564   4175 DD 5E 05        ld  e,(ix+5)
0565   4178 CD 70 5C        call    SET_DATE
0566   417B 3E 02           ld  a,2
0567   417D DD BE 00        cp  (ix+0)
0568   4180 20 16           jr  nz,INIT_NOCLOCKUPDATE
0569   4182                 ; First, release any hold to Wi-Fi Connection
0570   4182                 CLEAR_UART
0570   4182 3E 14       >    ld  a,20
0570   4184 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0571   4187 3E 68           ld  a,CMD_WIFIRELEASE_ESP
0572   4189                 SEND_DATA                       ; Just send, no need to wait response
0572   4189 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0573   418C                 ; And, turn off Wi-Fi Immediatelly
0574   418C                 CLEAR_UART
0574   418C 3E 14       >    ld  a,20
0574   418E 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0575   4191 3E 4F           ld  a,CMD_WIFI_OFF
0576   4193                 SEND_DATA                       ; Just send, no need to wait response
0576   4193 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0577   4196 18 0A           jr  INIT_NOCLOCKUPDAT2
0578   4198             INIT_NOCLOCKUPDATE:
0579   4198                 ; Release any hold to Wi-Fi Connection
0580   4198                 CLEAR_UART
0580   4198 3E 14       >    ld  a,20
0580   419A 32 06 7F    >    ld  (MEM_OUT_CMD_PORT),a            ; Clear UART
0581   419D 3E 68           ld  a,CMD_WIFIRELEASE_ESP
0582   419F                 SEND_DATA                       ; Just send, no need to wait response
0582   419F 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
0583   41A2             INIT_NOCLOCKUPDAT2:
0584   41A2                 ; Save existing EXTBIO hook if it exists
0585   41A2 3A 20 FB        ld  a,(HOKVLD)
0586   41A5 CB 47           bit 0,a
0587   41A7 20 0B           jr  nz,SAVE_HOOK2               ; HOKVLD tells us if there is an extended BIOS already or not, if yes, save it
0588   41A9                 ; If here, no extended BIOS
0589   41A9 CD 67 59        call    GETSLT
0590   41AC CD C0 59        call    GETWRK                  ; Our ROM work area address is at HL (we can use up to 8 bytes)
0591   41AF 3E C9           ld  a,#c9                       ; RET, as we are the first extended BIOS
0592   41B1 77              ld  (hl),a
0593   41B2 18 13           jr  PATCH                       ; And now all we need to do is patch the EXTBIO hook :)
0594   41B4             
0595   41B4             SAVE_HOOK2:
0596   41B4                 ; If here, we are not the first to extend bios, so we need to save the previous one
0597   41B4 CD 67 59        call    GETSLT
0598   41B7 CD C0 59        call    GETWRK                  ; Our ROM work area address is at HL (we can use up to 8 bytes)
0599   41BA EB              ex  de,hl                       ; It is the destination for....
0600   41BB 21 CA FF        ld  hl,EXTBIO                   ; The actual EXTBIO hook
0601   41BE 01 05 00        ld  bc,5                        ; That is 5 bytes large
0602   41C1 ED B0           ldir                            ; And move to our work area
0603   41C3 AF              xor a
0604   41C4 12              ld  (de),a                      ; Not initialized (de is at the sixth byte) of our slot work area
0605   41C5 13              inc de
0606   41C6 12              ld  (de),a                      ; Not initialized (de is at the seventh byte) of our slot work area
0607   41C7             
0608   41C7                 ; Patch EXTBIO
0609   41C7             PATCH:
0610   41C7 3E F7           ld  a,#F7                       ; RST #30
0611   41C9 32 CA FF        ld  (EXTBIO),a                  ; In EXTBIO hook
0612   41CC CD 67 59        call    GETSLT                  ; Our Slot in A
0613   41CF 32 CB FF        ld  (EXTBIO+1),a                ; Next EXTBIO hook byte
0614   41D2 21 D5 4C        ld  hl,DO_EXTBIO                ; Our EXTBIO routine address
0615   41D5 22 CC FF        ld  (EXTBIO+2),hl               ; Goes to the following two bytes in the hook
0616   41D8             
0617   41D8 21 CF FF        ld  hl,EXTBIO+5                 ; Must patch DISINT and ENAINT as well
0618   41DB 06 0A           ld  b,5*2
0619   41DD             PATCH2:
0620   41DD 36 C9           ld  (hl),#C9
0621   41DF 23              inc hl
0622   41E0 10 FB           djnz    PATCH2                  ; So patch all 10 bytes with return
0623   41E2             
0624   41E2 21 20 FB        ld  hl,HOKVLD
0625   41E5 CB C6           set 0,(hl)                      ; And set HOKVLD properly to indicate an EXTBIOS is installed
0626   41E7             INIT_OK:
0627   41E7                 if  NON_VERBOSE_ROM = 0
0628   41E7 21 3D 69        ld  hl,OK_S                     ; All done and set, nice exit message
0629   41EA CD 80 4C        call    PRINTHL
0630   41ED                 endif
0631   41ED 3E F0           ld  a,#F0                       ; Set #F0, UNAPI driver has been loaded at least once
0632   41EF                 WRITE_F2
0632   41EF 32 05 7F    >    ld  (MEM_PORT_F2),a
0633   41F2 C9              ret
