3355   522F             ;===  TCPIP_UDP_SEND  ===
3356   522F             ;========================
3357   522F             ;Send an UDP datagram.
3358   522F             ;
3359   522F             ;Input:  A = 11
3360   522F             ;        B = Connection number
3361   522F             ;        HL = Address of datagram data
3362   522F             ;        DE = Address of parameters block
3363   522F             ;Output: A = Error code
3364   522F             ;
3365   522F             ;Parameters block:
3366   522F             ;
3367   522F             ;    +0 (4): Destination IP address
3368   522F             ;    +4 (2): Destination port
3369   522F             ;    +6 (2): Data length
3370   522F             TCPIP_UDP_SEND:
