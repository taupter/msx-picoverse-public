3762   5429 18 F4           jr  TCPIP_TCP_OPEN_ERROR3
3763   542B             TCPIP_TCP_OPEN_ERROR3.1:
3764   542B                 ; nz, get it
3765   542B                 RECEIVE_DATA
3765   542B 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
3766   542E 4F              ld  c,a
3767   542F             TCPIP_TCP_OPEN_ERROR4:
3768   542F                 ; now return w/ error that is saved in b
