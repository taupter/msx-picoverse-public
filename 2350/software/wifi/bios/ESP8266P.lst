3474   52C0             ;===  TCPIP_UDP_RCV  ===
3475   52C0             ;=======================
3476   52C0             ;Retrieve an incoming UDP datagram.
3477   52C0             ;
3478   52C0             ;Input:  A = 12
3479   52C0             ;        B = Connection number
3480   52C0             ;        HL = Address for datagram data
3481   52C0             ;        DE = Maximum data size to retrieve
3482   52C0             ;Output: A = Error code
3483   52C0             ;        L.H.E.D = Source IP address
3484   52C0             ;        IX = Source port
3485   52C0             ;        BC = Actual received data size
3486   52C0             
3487   52C0             ; Customized TIME OUT routine: If time out receiving data, retry as received data
3488   52C0             ; won't be re-sent as host is unaware of this
3489   52C0             TCPIP_UDP_RCV_CHECK_TIME_OUT:
3490   52C0                 ; Save registers other than AF
3491   52C0 C5              push bc
3492   52C1 D5              push de
3493   52C2 E5              push hl
3494   52C3 CD F8 59        call    GETCOUNTER
3495   52C6 7D              ld  a,l
3496   52C7 B4              or  h
3497   52C8                 ; Restore registers, we are returning
3498   52C8 E1              pop hl
3499   52C9 D1              pop de
3500   52CA C1              pop bc
3501   52CB C0              ret nz
3502   52CC                 ; Ok, timeout...
3503   52CC F1              pop af                          ; Get return address of who called this out of the stack, we will return from the function or re-start
3504   52CD             TCPIP_TCP_UDP_RETRY_QRCV:
3505   52CD CD 17 5A        call    GETBYTE
