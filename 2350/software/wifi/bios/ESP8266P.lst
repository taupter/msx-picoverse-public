3781   543A 21 0B 00        ld  hl,11
3782   543D CD 50 5A        call    SETWORD                 ; If it is non-TLS, send 11 bytes
3783   5440 DD 7E 0A        ld  a,(ix+10)                   ; TCP_OPEN_CMD_FLAGS
