5875   5D9A             ; Cold reset of ESP firmware
5876   5D9A             CMD_RESET_ESP           equ 'R'
5877   5D9A             ; Warm reset of ESP firmware
5878   5D9A             CMD_WRESET_ESP          equ 'W'
5879   5D9A             ; Hold Wi-Fi Connection On
5880   5D9A             CMD_WIFIHOLD_ESP        equ 'H'
5881   5D9A             ; Release Wi-Fi Connection Hold
5882   5D9A             CMD_WIFIRELEASE_ESP     equ 'h'
5883   5D9A             ; Get Updated time and date from internet
5884   5D9A             CMD_GET_TIME            equ 'G'
5885   5D9A             ; Query Auto Clock settings
5886   5D9A             CMD_QUERY_ACLK_SETTINGS equ 'c'
5887   5D9A             ; Set Auto Clock settings
5888   5D9A             CMD_SET_ACLK_SETTINGS   equ 'C'
5889   5D9A             ; Query ESP settings
5890   5D9A             CMD_QUERY_ESP_SETTINGS  equ 'Q'
5891   5D9A             ; Set Timer Value
5892   5D9A             CMD_TIMER_SET           equ 'T'
5893   5D9A             ; Turn Nagle On
5894   5D9A             CMD_NAGLE_ON            equ 'D'
5895   5D9A             ; Turn Nagle Off
5896   5D9A             CMD_NAGLE_OFF           equ 'N'
5897   5D9A             ; Turn Wi-Fi Off
5898   5D9A             CMD_WIFI_OFF            equ 'O'
5899   5D9A             ; Request to connect to a network
5900   5D9A             CMD_WIFI_CONNECT        equ 'A'
5901   5D9A             ; Request to start network scan
5902   5D9A             CMD_SCAN_START          equ 'S'
5903   5D9A             ; Request network scan result
5904   5D9A             CMD_SCAN_RESULTS        equ 's'
5905   5D9A             ; Request AP Status
5906   5D9A             CMD_AP_STS              equ 'g'
5907   5D9A             ; Get ESP firmware version
5908   5D9A             CMD_GET_ESP_VER         equ 'V'
