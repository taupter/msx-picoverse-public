2611   4E5C 47              ld  b,a
2612   4E5D             TCPIP_GET_CAPAB_BLK2_ST2:
2613   4E5D                 CHECK_DATA
2613   4E5D 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2613   4E60 CB 47       >    bit 0,a                         ; If nz has data
2614   4E62 20 05           jr  nz,TCPIP_GET_CAPAB_BLK2_ST2.1
2615   4E64 CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2616   4E67 18 F4           jr  TCPIP_GET_CAPAB_BLK2_ST2
2617   4E69             TCPIP_GET_CAPAB_BLK2_ST2.1:
2618   4E69                 ; nz, get it
2619   4E69                 RECEIVE_DATA
2619   4E69 3A 06 7F    >    ld a,(MEM_IN_DATA_PORT)
2620   4E6C 4F              ld  c,a
2621   4E6D             TCPIP_GET_CAPAB_BLK2_ST3:
2622   4E6D                 CHECK_DATA
2622   4E6D 3A 07 7F    >    ld  a,(MEM_IN_STS_PORT)
2622   4E70 CB 47       >    bit 0,a                         ; If nz has data
2623   4E72 20 05           jr  nz,TCPIP_GET_CAPAB_BLK2_ST3.1
2624   4E74 CD 8E 4D        call    TCPIP_GENERIC_CHECK_TIME_OUT
2625   4E77 18 F4           jr  TCPIP_GET_CAPAB_BLK2_ST3
2626   4E79             TCPIP_GET_CAPAB_BLK2_ST3.1:
2627   4E79                 ; nz, get it
