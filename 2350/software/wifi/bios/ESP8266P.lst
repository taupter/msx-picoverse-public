2227   4CC7 28 04           jr  z,DO_HTIMI_END              ; If it is, nothing to do
2228   4CC9 2B              dec hl                          ; Otherwise decrement it
2229   4CCA CD 07 5A        call    SETCOUNTER              ; And save it
2230   4CCD             DO_HTIMI_END:
