4472   57B5                 SEND_DATA                       ; Send the command
4472   57B5 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4473   57B8 AF              xor a
4474   57B9                 SEND_DATA                       ; Send the command size msb
4474   57B9 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4475   57BC 3E 03           ld  a,3
4476   57BE                 SEND_DATA                       ; Send the command size lsb
4476   57BE 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4477   57C1 78              ld  a,b
4478   57C2                 SEND_DATA                       ; Send the connection #
4478   57C2 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4479   57C5 7D              ld  a,l
4480   57C6                 SEND_DATA                       ; Send MAX rcv size LSB
4480   57C6 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4481   57C9 7C              ld  a,h
4482   57CA                 SEND_DATA                       ; Send MAX rcv size MSB
4482   57CA 32 07 7F    >    ld  (MEM_OUT_TX_PORT),a             ; Just send, no need to wait response
4483   57CD 3E 03           ld  a,3
4484   57CF CD 29 5A        call    SETBYTE                 ; Ok, retry up to three times
