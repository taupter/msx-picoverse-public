4760   5945             ;==========================
4761   5945             ;===  TCPIP_CONFIG_TTL  ===
4762   5945             ;==========================
4763   5945             ;Get/set the value of TTL and TOS for outgoing datagrams.
4764   5945             ;
4765   5945             ;Input:  A = 27
4766   5945             ;        B = 0: Get current values (just return 255 for TTL and 0 for TOS
4767   5945             ;               as ESP do not expose or allow configurations of it)
4768   5945             ;            1: Set values
4769   5945             ;        D = New value for TTL (only if B=1)
4770   5945             ;        E = New value for ToS (only if B=1)
4771   5945             ;Output: A = Error code
4772   5945             ;        D = Value of TTL after the routine execution
4773   5945             ;        E = Value of ToS after the routine execution
4774   5945             TCPIP_CONFIG_TTL:
4775   5945 78              ld  a,b
4776   5946 E6 FE           and %11111110
4777   5948 B7              or  a
4778   5949 3E 04           ld  a,ERR_INV_PARAM
4779   594B C0              ret nz
4780   594C 78              ld  a,b
4781   594D B7              or  a
4782   594E                 ; Cant set, so NOT IMP
4783   594E 3E 01           ld  a,ERR_NOT_IMP
4784   5950 C0              ret nz                          ; if not get, not implemented
4785   5951                 ; get, so just return D = #FF, A = OK = 0 and E = 0
4786   5951 AF              xor a
4787   5952 1E 00           ld  e,0
4788   5954 16 FF           ld  d,#FF
4789   5956 C9              ret
4790   5957             
4791   5957             ;===========================
4792   5957             ;===  TCPIP_CONFIG_PING  ===
4793   5957             ;===========================
4794   5957             ;Get/set the automatic PING reply flag.
4795   5957             ;
4796   5957             ;Input:  A = 28
4797   5957             ;        B = 0: Get current flag value
4798   5957             ;            1: Set flag value (ERR_NOT_IMP)
4799   5957             ;        C = New flag value (only if B=1):
4800   5957             ;            0: Off
4801   5957             ;            1: On
4802   5957             ;Output: A = Error code
4803   5957             ;        C = Flag value after the routine execution
4804   5957             TCPIP_CONFIG_PING:
4805   5957 78              ld  a,b
4806   5958 E6 FE           and %11111110
4807   595A B7              or  a
4808   595B 3E 04           ld  a,ERR_INV_PARAM
4809   595D C0              ret nz
4810   595E 78              ld  a,b
4811   595F B7              or  a
4812   5960                 ; Cant set, so NOT IMP
4813   5960 3E 01           ld  a,ERR_NOT_IMP
4814   5962 C0              ret nz                          ; if not get, not implemented
4815   5963                 ; get, so just return C = 1, A = OK = 0
4816   5963 AF              xor a
4817   5964 0E 01           ld  c,1
4818   5966 C9              ret
