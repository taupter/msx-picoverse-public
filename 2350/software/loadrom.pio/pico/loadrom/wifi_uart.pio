; Minimal PIO UART backend for the Sunrise WiFi memio bridge.
; TX and RX both run at 8 cycles per bit.

.pio_version 0

.program wifi_uart_tx
.side_set 1 opt

    pull       side 1 [7]
    set x, 7   side 0 [7]
bitloop:
    out pins, 1
    jmp x-- bitloop [6]

.program wifi_uart_rx

start:
    wait 0 pin 0
    set x, 7    [10]
bitloop:
    in pins, 1
    jmp x-- bitloop [6]
    jmp pin good_stop
    irq 4 rel
    wait 1 pin 0
    jmp start
good_stop:
    push
